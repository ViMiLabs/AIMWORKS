  <rdf:Description rdf:about="https://w3id.org/h2kg/hydrogen-ontology#RamanI2DToIGRatio">
    <rdf:type rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Property"/>
    <skos:prefLabel xml:lang="en">Raman I 2 D To IG Ratio</skos:prefLabel>
    <rdfs:label xml:lang="en">Raman I 2 D To IG Ratio</rdfs:label>
    <skos:altLabel xml:lang="en">I2D/IG</skos:altLabel>
    <dcterms:description xml:lang="en">Intensity ratio of Raman 2D band to G band used to indicate graphene stacking/restacking.</dcterms:description>
    <h2kg:hasQuantityValue rdf:resource="file:///C:/Users/mehrt/Desktop/h2kg/AIMWORKS/ontology_release/output/ontology/_RamanI2DToIGRatio_QV"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/h2kg/hydrogen-ontology#InkPreparationBurningReaction">
    <rdf:type rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Manufacturing"/>
    <skos:prefLabel xml:lang="en">Ink Preparation Burning Reaction</skos:prefLabel>
    <rdfs:label xml:lang="en">Ink Preparation Burning Reaction</rdfs:label>
    <skos:altLabel xml:lang="en">burning reaction</skos:altLabel>
    <skos:altLabel xml:lang="en">purposely burning reaction</skos:altLabel>
    <dcterms:description xml:lang="en">Occurs when Nafion solution or isopropyl alcohol contacts dry Pt/C during ink preparation; reported to cause exothermic 'burning reaction' leading to Pt nanoparticle agglomeration and reduced BET surface area/ECSA.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/h2kg/hydrogen-ontology#TemplateRemovalDuration">

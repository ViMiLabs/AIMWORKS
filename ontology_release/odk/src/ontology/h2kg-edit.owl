    <rdfs:label xml:lang="en">Template Removal Duration</rdfs:label>
    <dcterms:description xml:lang="en">Duration of acid quench step to remove ferritin template.</dcterms:description>
    <h2kg:hasQuantityValue rdf:resource="file:///C:/Users/mehrt/Desktop/h2kg/AIMWORKS/ontology_release/output/ontology/_TemplateRemovalDuration_QV"/>

<https://w3id.org/h2kg/hydrogen-ontology>
  a owl:Ontology ;
  dcterms:title "H2KG: Ontology for Proton Exchange Membrane Fuel Cell Materials, Components, and Experiments" ;
  dcterms:description "Ontology for representing proton exchange membrane fuel cell materials, components, devices, processes, measurements, and experiments." ;
  dcterms:creator "Electrochemistry Research Group" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:references <https://w3id.org/emmo/domain/pemfc>, <http://purl.org/holy/ns#>, <https://w3id.org/emmo>, <https://w3id.org/emmo/domain/manufacturing#>, <https://w3id.org/emmo/domain/coating#>, <https://w3id.org/emmo/domain/equivalent-circuit-model#>, <https://w3id.org/emmo/domain/characterisation-methodology/chameo#>, <https://w3id.org/emmo/domain/microscopy#>, <https://w3id.org/emmo/domain/electrochemistry> ;
  rdfs:seeAlso pemfc:EMMO_01f7c538_3de2_4028_92c1_8cc93832dd76, pemfc:EMMO_099d5163_117a_4176_ba48_af54a61c4c8d, pemfc:EMMO_143d21b5_d044_4af3_a9f9_22928f2516c1, pemfc:EMMO_2ffda0a1_a5fc_4a55_aad8_d91d7cbb101d, pemfc:EMMO_6da0e770_9dcf_43ff_865f_21121a53ca67, pemfc:EMMO_9d51634d_db42_4697_8dda_58e74a8df826, pemfc:EMMO_e072436a_2656_4e03_b600_a7f41c486339, pemfc:EMMO_abe17c61_6a3d_4ec6_b4db_450b5654dbc6, pemfc:EMMO_b24401b7_35e4_40be_8c8b_36ee8869cc1a, holy:FuelCellStack, holy:Gasket, holy:CatalystLayer, holy:Membrane, holy:BipolarPlate, holy:MembraneElectrodeAssembly, holy:GasDiffusionLayer, holy:PolymerElectrolyteMembraneFuelCell, <https://www.fz-juelich.de/en/iet/iet-3/divisions-1/artificial-material-intelligence>, electrochemistry:electrochemistry_a9fc3f77_e48e_4bce_b118_044d608722f6, electrochemistry:electrochemistry_7729c34e_1ae9_403d_b933_1765885e7f29, electrochemistry:electrochemistry_80263f65_7f6c_477a_8818_a85080f74c24, electrochemistry:electrochemistry_31f4498b_aeb1_47b9_8bb8_8b0f55ed6a56, electrochemistry:electrochemistry_03a0ccc9_21fe_46a1_a143_50147fbe3200, electrochemistry:electrochemistry_4edc0d47_1f7e_4cb2_b710_7f76b76742bc, electrochemistry:electrochemistry_f3345489_17f2_4a8e_a74b_6e81f19180a7, electrochemistry:electrochemistry_c6605d77_6b8c_42ce_9f7d_befeddb5d5f2 ;
  dcterms:contributor "Institute of Energy Technologies (IET), Theory and Computation of Energy Materials (IET-3), Forschungszentrum Juelich GmbH, 52428 Juelich, Germany" ;
  dcterms:publisher "Forschungszentrum Juelich GmbH" ;
  owl:imports <https://w3id.org/emmo/domain/pemfc>, <http://purl.org/holy/ns#>, <https://w3id.org/emmo>, <https://w3id.org/emmo/domain/manufacturing#>, <https://w3id.org/emmo/domain/coating#>, <https://w3id.org/emmo/domain/equivalent-circuit-model#>, <https://w3id.org/emmo/domain/characterisation-methodology/chameo#>, <https://w3id.org/emmo/domain/microscopy#>, <https://w3id.org/emmo/domain/electrochemistry> ;
  foaf:homepage <https://www.fz-juelich.de/en/iet/iet-3/divisions-1/artificial-material-intelligence> ;
  owl:versionInfo "1.0.0"@en ;
  dcterms:abstract "Application ontology for representing low-Pt PEMFC cathode catalyst layer experiments, materials, manufacturing conditions, measurements, quantities, and release metadata with conservative alignment to EMMO, ECHO, QUDT, ChEBI, PROV-O, and Dublin Core Terms.\n"@en ;
  dcterms:created "2026-03-19" ;
  dcterms:modified "2026-03-19" ;
  owl:versionIRI <https://w3id.org/h2kg/hydrogen-ontology/releases/1.0.0> ;
  owl:priorVersion <https://w3id.org/h2kg/hydrogen-ontology> ;
  vann:preferredNamespacePrefix "h2kg" ;
  vann:preferredNamespaceUri <https://w3id.org/h2kg/hydrogen-ontology#> ;
  rdfs:comment "The ontology captures PEMFC catalyst-layer experimental concepts, parameters, properties, measurements, instruments, materials, and related FAIR provenance. It preserves the historic h2kg namespace while improving metadata quality, release readiness, and public documentation.\n"@en .

h2kg:hasParameter
  a owl:ObjectProperty ;
  rdfs:domain h2kg:Process ;
  rdfs:range h2kg:Parameter ;
  rdfs:label "hasParameter"@en ;
  skos:definition "Object property used to relate two resources within the H2KG PEMFC catalyst-layer application ontology."@en ;
  rdfs:comment "hasParameter is a local H2KG relation preserved for backward-compatible release preparation."@en ;
  rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> .


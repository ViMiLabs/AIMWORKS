<https://w3id.org/h2kg/pemfc/hydrogen-ontology>
  a owl:Ontology ;
  dcterms:title "H2KG PEMFC Application Ontology"@en ;
  dcterms:description "Profile ontology module for H2KG PEMFC Application Ontology. This module preserves stable H2KG core term IRIs and scopes terms for profile publication."@en ;
  owl:versionInfo "1.0.0"@en ;
  owl:versionIRI <https://w3id.org/h2kg/pemfc/hydrogen-ontology/releases/1.0.0> ;
  vann:preferredNamespacePrefix "h2kg-pemfc" ;
  vann:preferredNamespaceUri <https://w3id.org/h2kg/pemfc/hydrogen-ontology#> ;
  owl:imports <https://w3id.org/h2kg/hydrogen-ontology> .


  skos:prefLabel "Surface Preparation Specification"@en ;
  rdfs:label "Surface Preparation Specification"@en ;
  dcterms:description "Tabulated/specification-like numeric parameters describing Pt(111) substrate preparation and geometry (annealing T/time, dimensions)."@en ;
  h2kg:hasInputMaterial h2kg:Pt111Surface ;
  h2kg:hasParameter h2kg:AnnealingTemperature, h2kg:AnnealingDuration, h2kg:PtCrystalDiameter, h2kg:PtCrystalThickness ;
  h2kg:appliesToProfile <https://w3id.org/h2kg/pemfc/hydrogen-ontology>, <https://w3id.org/h2kg/pemwe/hydrogen-ontology> ;
  rdfs:isDefinedBy <https://w3id.org/h2kg/pemfc/hydrogen-ontology> .

h2kg:WaterToNPropanolVolumeRatio
  a h2kg:Parameter ;
  skos:prefLabel "Water To N Propanol Volume Ratio"@en ;
  rdfs:label "Water To N Propanol Volume Ratio"@en ;
  skos:altLabel "H2O/alcohol volume ratio"@en, "H2O/n-PA volume ratio"@en, "water:propanol ratio"@en ;
  dcterms:description "Paper reports H2O/alcohol volume ratio = 1.3 (alcohol = n-propanol). Not found as a specific ontology term (molar ratio terms exist for ethanol/isopropanol)."@en ;
  h2kg:hasQuantityValue <_WaterToNPropanolVolumeRatio_QV> ;
  h2kg:appliesToProfile <https://w3id.org/h2kg/pemfc/hydrogen-ontology>, <https://w3id.org/h2kg/pemwe/hydrogen-ontology> ;
  rdfs:isDefinedBy <https://w3id.org/h2kg/pemfc/hydrogen-ontology> .


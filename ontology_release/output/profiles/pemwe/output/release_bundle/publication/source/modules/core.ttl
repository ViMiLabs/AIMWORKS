@prefix ns2: <https://w3id.org/h2kg/hydrogen-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

ns2:Agent a owl:Class ;
    rdfs:label "Agent"@en ;
    rdfs:comment "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Agent."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    rdfs:subClassOf prov:Agent ;
    owl:equivalentClass prov:Agent ;
    skos:definition "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Agent."@en .

ns2:Data a owl:Class ;
    rdfs:label "Data"@en ;
    rdfs:comment "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Data."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    rdfs:subClassOf prov:Entity,
        <https://w3id.org/emmo#EMMO_194e367c_9783_4bf5_96d0_9ad597d48d9a> ;
    skos:definition "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Data."@en .

ns2:DataPoint a owl:Class ;
    rdfs:label "Data Point"@en ;
    rdfs:comment "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Data Point."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    rdfs:subClassOf prov:Entity,
        <https://w3id.org/emmo#EMMO_194e367c_9783_4bf5_96d0_9ad597d48d9a> ;
    skos:definition "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Data Point."@en .

ns2:GeometricArea a ns2:NormalizationBasis ;
    rdfs:label "Geometric Area"@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Geometric Area."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "MEA active area"@en,
        "active area"@en,
        "active area (geometric)"@en,
        "active area normalization"@en,
        "cell area"@en,
        "cm2 geometric area"@en,
        "cm2_geo"@en,
        "cm^2_geo"@en,
        "electrode area"@en,
        "geometric area basis"@en,
        "geometric surface area"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Geometric Area."@en ;
    skos:prefLabel "Geometric Area"@en ;
    ns2:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_GeometricArea_QV> .

ns2:Measurement a owl:Class ;
    rdfs:label "Measurement"@en ;
    rdfs:comment "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Measurement."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    rdfs:subClassOf <https://w3id.org/emmo/domain/electrochemistry#electrochemistry_f4ce4df2_d7e6_470f_8eab_3a911adaaf0f>,
        ns2:Process ;
    skos:definition "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Measurement."@en .

ns2:Metadata a owl:Class ;
    rdfs:label "Metadata"@en ;
    rdfs:comment "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Metadata."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    rdfs:subClassOf prov:Entity ;
    skos:definition "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Metadata."@en .

ns2:Parameter a owl:Class ;
    rdfs:label "Parameter"@en ;
    rdfs:comment "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Parameter."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:definition "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Parameter."@en .

ns2:Property a owl:Class ;
    rdfs:label "Property"@en ;
    rdfs:comment "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Property."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    rdfs:subClassOf <https://w3id.org/emmo#EMMO_2480b72b_db8d_460f_9a5f_c2912f979046> ;
    skos:definition "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Property."@en .

ns2:Unit a owl:Class ;
    rdfs:label "Unit"@en ;
    rdfs:comment "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Unit."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:definition "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Unit."@en .

ns2:NormalizationBasis a owl:Class ;
    rdfs:label "Normalization Basis"@en ;
    rdfs:comment "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Normalization Basis."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:definition "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Normalization Basis."@en .

ns2:Process a owl:Class ;
    rdfs:label "Process"@en ;
    rdfs:comment "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Process."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    rdfs:subClassOf prov:Activity,
        <https://w3id.org/emmo#EMMO_472a0ca2_58bf_4618_b561_6fe68bd9fd49> ;
    skos:definition "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Process."@en .


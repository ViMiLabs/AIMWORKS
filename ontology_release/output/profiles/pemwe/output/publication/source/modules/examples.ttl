        <http://qudt.org/vocab/unit/SEC> .

[] a ns11:QuantityValue ;
    ns11:quantityKind <http://qudt.org/vocab/quantitykind/ThermodynamicTemperature> ;
    ns11:unit <http://qudt.org/vocab/unit/DEG_C> .

[] a ns11:QuantityValue ;
    ns11:quantityKind <http://qudt.org/vocab/quantitykind/AmountConcentration>,
        <http://qudt.org/vocab/quantitykind/AmountOfSubstanceConcentration>,
        <http://qudt.org/vocab/quantitykind/MolarConcentration> ;
    ns11:unit <http://qudt.org/vocab/unit/MOL-PER-L> .

[] a ns11:QuantityValue ;
    ns11:quantityKind <http://qudt.org/vocab/quantitykind/Temperature>,
        <http://qudt.org/vocab/quantitykind/ThermodynamicTemperature> ;
    ns11:unit <http://qudt.org/vocab/unit/DEG_C>,
        <http://qudt.org/vocab/unit/K> .

[] a ns11:QuantityValue ;
    ns11:quantityKind <http://qudt.org/vocab/quantitykind/MassArealDensity>,
        <http://qudt.org/vocab/quantitykind/MassLoading>,
        <http://qudt.org/vocab/quantitykind/MassLoadingPerArea>,
        <http://qudt.org/vocab/quantitykind/MassPerArea> ;
    ns11:unit <http://qudt.org/vocab/unit/MilliGM-PER-CentiM2> .

[] a ns11:QuantityValue ;
    ns11:quantityKind <http://qudt.org/vocab/quantitykind/AreaPerMass>,
        <http://qudt.org/vocab/quantitykind/ElectrochemicallyActiveSurfaceArea> ;
    ns11:unit <http://qudt.org/vocab/unit/M2-PER-GM> .

[] a ns2:DataPoint ;
    ns2:hasQuantityValue [ a ns11:QuantityValue ;
            ns11:quantityKind <http://qudt.org/vocab/quantitykind/ElectricPotential> ;
            ns11:unit <http://qudt.org/vocab/unit/MilliV> ] ;
    ns2:ofProperty ns2:Overpotential .

[] a ns11:QuantityValue ;
    ns11:quantityKind <http://qudt.org/vocab/quantitykind/Capacitance>,
        <http://qudt.org/vocab/quantitykind/CapacitancePerArea> ;
    ns11:unit <http://qudt.org/vocab/unit/FARAD-PER-CentiM2> .

[] a ns11:QuantityValue ;
    ns11:quantityKind <http://qudt.org/vocab/quantitykind/Dimensionless>,
        <http://qudt.org/vocab/quantitykind/RelativeHumidity> ;
    ns11:unit <http://qudt.org/vocab/unit/PERCENT> .

[] a ns11:QuantityValue ;
    ns11:quantityKind <http://qudt.org/vocab/quantitykind/ElectricCurrentDensity> ;
    ns11:unit <http://qudt.org/vocab/unit/MilliA-PER-CentiM2> .

[] a ns2:DataPoint ;
    ns2:hasQuantityValue [ a ns11:QuantityValue ;
            ns11:quantityKind <http://qudt.org/vocab/quantitykind/Resistance> ;
            ns11:unit <http://qudt.org/vocab/unit/OHM> ] ;
    ns2:ofProperty ns2:ChargeTransferResistance .

[] a ns11:QuantityValue ;
    ns11:quantityKind <http://qudt.org/vocab/quantitykind/Dimensionless>,
        <http://qudt.org/vocab/quantitykind/DimensionlessRatio>,
        <http://qudt.org/vocab/quantitykind/ElectricCurrent>,

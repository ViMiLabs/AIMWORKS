[] a ns2:DataPoint ;
    ns2:hasQuantityValue [ a ns11:QuantityValue ;
            ns11:quantityKind <http://qudt.org/vocab/quantitykind/ElectricCurrentDensity> ;
            ns11:unit <http://qudt.org/vocab/unit/MilliA-PER-CentiM2> ] ;
    ns2:normalizedTo ns2:GeometricArea ;
    ns2:ofProperty ns2:ExchangeCurrentDensity .

[] a ns2:DataPoint ;
    ns2:hasQuantityValue [ a ns11:QuantityValue ;
            ns11:quantityKind <http://qudt.org/vocab/quantitykind/ElectricCurrentPerMass> ;
            ns11:unit <http://qudt.org/vocab/unit/A-PER-GM> ] ;
    ns2:normalizedTo ns2:CatalystMass ;
    ns2:ofProperty ns2:MassActivity .

[] a ns2:DataPoint ;
    ns2:hasQuantityValue [ a ns11:QuantityValue ;
            ns11:quantityKind <http://qudt.org/vocab/quantitykind/ElectricPotential> ;
            ns11:unit <http://qudt.org/vocab/unit/MilliV> ] ;
    ns2:ofProperty ns2:Overpotential .

[] a ns2:DataPoint ;
    ns2:hasQuantityValue [ a ns11:QuantityValue ;
            ns11:quantityKind <http://qudt.org/vocab/quantitykind/Resistance> ;
            ns11:unit <http://qudt.org/vocab/unit/OHM> ] ;
    ns2:ofProperty ns2:ChargeTransferResistance .

[] a ns2:DataPoint ;
    ns2:hasQuantityValue [ a ns11:QuantityValue ;
            ns11:quantityKind <http://qudt.org/vocab/quantitykind/Capacitance> ;
            ns11:unit <http://qudt.org/vocab/unit/FARAD-PER-CentiM2> ] ;
    ns2:ofProperty ns2:DoubleLayerCapacitance .


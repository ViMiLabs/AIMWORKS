[] a ns2:QuantityValue ;
    ns2:quantityKind <http://qudt.org/vocab/quantitykind/Duration>,
        <http://qudt.org/vocab/quantitykind/Time>,
        <http://qudt.org/vocab/quantitykind/TimeDuration> ;
    ns2:unit <http://qudt.org/vocab/unit/HR>,
        <http://qudt.org/vocab/unit/MIN>,
        <http://qudt.org/vocab/unit/SEC> .

[] a ns2:QuantityValue ;
    ns2:quantityKind <http://qudt.org/vocab/quantitykind/ThermodynamicTemperature> ;
    ns2:unit <http://qudt.org/vocab/unit/DEG_C> .

[] a ns2:QuantityValue ;
    ns2:quantityKind <http://qudt.org/vocab/quantitykind/AmountConcentration>,
        <http://qudt.org/vocab/quantitykind/AmountOfSubstanceConcentration>,
        <http://qudt.org/vocab/quantitykind/MolarConcentration> ;
    ns2:unit <http://qudt.org/vocab/unit/MOL-PER-L> .

[] a ns2:QuantityValue ;
    ns2:quantityKind <http://qudt.org/vocab/quantitykind/Temperature>,
        <http://qudt.org/vocab/quantitykind/ThermodynamicTemperature> ;
    ns2:unit <http://qudt.org/vocab/unit/DEG_C>,
        <http://qudt.org/vocab/unit/K> .

[] a ns2:QuantityValue ;
    ns2:quantityKind <http://qudt.org/vocab/quantitykind/MassArealDensity>,
        <http://qudt.org/vocab/quantitykind/MassLoading>,
        <http://qudt.org/vocab/quantitykind/MassLoadingPerArea>,
        <http://qudt.org/vocab/quantitykind/MassPerArea> ;
    ns2:unit <http://qudt.org/vocab/unit/MilliGM-PER-CentiM2> .

[] a ns2:QuantityValue ;
    ns2:quantityKind <http://qudt.org/vocab/quantitykind/AreaPerMass>,
        <http://qudt.org/vocab/quantitykind/ElectrochemicallyActiveSurfaceArea> ;
    ns2:unit <http://qudt.org/vocab/unit/M2-PER-GM> .

[] a ns1:DataPoint ;
    ns1:hasQuantityValue [ a ns2:QuantityValue ;
            ns2:quantityKind <http://qudt.org/vocab/quantitykind/ElectricPotential> ;
            ns2:unit <http://qudt.org/vocab/unit/MilliV> ] ;
    ns1:ofProperty ns1:Overpotential .

[] a ns2:QuantityValue ;
    ns2:quantityKind <http://qudt.org/vocab/quantitykind/Capacitance>,
        <http://qudt.org/vocab/quantitykind/CapacitancePerArea> ;
    ns2:unit <http://qudt.org/vocab/unit/FARAD-PER-CentiM2> .

[] a ns2:QuantityValue ;
    ns2:quantityKind <http://qudt.org/vocab/quantitykind/Dimensionless>,
        <http://qudt.org/vocab/quantitykind/RelativeHumidity> ;
    ns2:unit <http://qudt.org/vocab/unit/PERCENT> .

[] a ns2:QuantityValue ;
    ns2:quantityKind <http://qudt.org/vocab/quantitykind/ElectricCurrentDensity> ;
    ns2:unit <http://qudt.org/vocab/unit/MilliA-PER-CentiM2> .

[] a ns1:DataPoint ;
    ns1:hasQuantityValue [ a ns2:QuantityValue ;
            ns2:quantityKind <http://qudt.org/vocab/quantitykind/Resistance> ;
            ns2:unit <http://qudt.org/vocab/unit/OHM> ] ;
    ns1:ofProperty ns1:ChargeTransferResistance .

[] a ns2:QuantityValue ;
    ns2:quantityKind <http://qudt.org/vocab/quantitykind/Dimensionless>,
        <http://qudt.org/vocab/quantitykind/DimensionlessRatio>,
        <http://qudt.org/vocab/quantitykind/ElectricCurrent>,
        <http://qudt.org/vocab/quantitykind/ElectricPotential>,
        <http://qudt.org/vocab/quantitykind/Voltage> ;
    ns2:unit <http://qudt.org/vocab/unit/A>,
        <http://qudt.org/vocab/unit/MilliA>,
        <http://qudt.org/vocab/unit/MilliV>,
        <http://qudt.org/vocab/unit/PERCENT> .

[] a ns1:DataPoint ;
    ns1:hasQuantityValue [ a ns2:QuantityValue ;
            ns2:quantityKind <http://qudt.org/vocab/quantitykind/Capacitance> ;
            ns2:unit <http://qudt.org/vocab/unit/FARAD-PER-CentiM2> ] ;
    ns1:ofProperty ns1:DoubleLayerCapacitance .


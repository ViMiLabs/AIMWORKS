<https://w3id.org/h2kg/hydrogen-ontology> a owl:Ontology ;
    dcterms:abstract "A release-ready, FAIR-oriented, EMMO-aligned application ontology for PEMFC catalyst-layer experiments and associated provenance-aware resources."@en ;
    dcterms:contributor "AIMWORKS Ontology Engineering Team"@en ;
    dcterms:created "2026-03-12"^^xsd:date ;
    dcterms:creator "Electrochemistry Research Group"@en ;
    dcterms:description "Ontology for low-Pt PEMFC cathode catalyst-layer experiments, measurements, materials, provenance, and curated reference terms."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:modified "2026-03-14" ;
    dcterms:source <https://w3id.org/h2kg/hydrogen-ontology> ;
    dcterms:title "H2KG PEMFC Catalyst Layer Application Ontology"@en ;
    vann:preferredNamespacePrefix "h2kg" ;
    vann:preferredNamespaceUri ns2: ;
    owl:versionIRI <https://w3id.org/h2kg/hydrogen-ontology/releases/2026.3.0> ;
    owl:versionInfo "Generated on 2025-11-28 16:12:13" .

[] a ns2:DataPoint ;
    ns2:hasQuantityValue [ a ns1:QuantityValue ;
            ns1:quantityKind <http://qudt.org/vocab/quantitykind/ElectricCurrentDensity> ;
            ns1:unit <http://qudt.org/vocab/unit/MilliA-PER-CentiM2> ] ;
    ns2:normalizedTo ns2:GeometricArea ;
    ns2:ofProperty ns2:ExchangeCurrentDensity .

[] a ns2:DataPoint ;
    ns2:hasQuantityValue [ a ns1:QuantityValue ;
            ns1:quantityKind <http://qudt.org/vocab/quantitykind/ElectricCurrentPerMass> ;
            ns1:unit <http://qudt.org/vocab/unit/A-PER-GM> ] ;
    ns2:normalizedTo ns2:CatalystMass ;
    ns2:ofProperty ns2:MassActivity .

[] a ns2:DataPoint ;
    ns2:hasQuantityValue [ a ns1:QuantityValue ;
            ns1:quantityKind <http://qudt.org/vocab/quantitykind/ElectricPotential> ;
            ns1:unit <http://qudt.org/vocab/unit/MilliV> ] ;
    ns2:ofProperty ns2:Overpotential .

[] a ns2:DataPoint ;
    ns2:hasQuantityValue [ a ns1:QuantityValue ;
            ns1:quantityKind <http://qudt.org/vocab/quantitykind/Resistance> ;
            ns1:unit <http://qudt.org/vocab/unit/OHM> ] ;
    ns2:ofProperty ns2:ChargeTransferResistance .

[] a ns2:DataPoint ;
    ns2:hasQuantityValue [ a ns1:QuantityValue ;
            ns1:quantityKind <http://qudt.org/vocab/quantitykind/Capacitance> ;
            ns1:unit <http://qudt.org/vocab/unit/FARAD-PER-CentiM2> ] ;
    ns2:ofProperty ns2:DoubleLayerCapacitance .


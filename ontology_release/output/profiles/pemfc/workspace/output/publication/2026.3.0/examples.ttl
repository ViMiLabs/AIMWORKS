        ns1:IonomerFilmThickness,
        ns1:PoreRadius,
        ns1:PoreVolumeFraction ;
    ns1:measures ns1:IonicResistance,
        ns1:IonomerFilmOxygenTransportResistivity,
        ns1:IonomerOxygenTransportResistanceComponent .

ns1:UVAssistedDirectInkWriting a ns1:Manufacturing ;
    rdfs:label "UV Assisted Direct Ink Writing"@en ;

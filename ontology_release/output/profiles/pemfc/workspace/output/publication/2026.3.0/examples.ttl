    dcterms:description "Electron microscopy imaging used in this review to report ionomer coverage and Pt particle size (e.g., Fig. 12(b), Fig. 8(a))."@en ;
    skos:altLabel "HAADF-STEM"@en,
        "HR-TEM"@en,
        "HRTEM"@en,
        "Nafion thickness"@en,
        "Pt size"@en,
        "SAED"@en,
        "TEM"@en,
        "TEM imaging"@en,
        "accelerating voltage"@en,
        "transmission electron microscopy"@en ;
    skos:prefLabel "Transmission Electron Microscopy Imaging"@en ;
    ns1:hasOutputData ns1:MicrostructureImageDataset ;
    ns1:measures ns1:CarbonNanotubeOuterDiameter,
        ns1:CarbonPrimaryParticleDiameter,
        ns1:CarbonShellThickness,
        ns1:InterplanarLatticeSpacing,
        ns1:InterplanarSpacing,
        ns1:IonomerFilmThickness,
        ns1:MeanParticleSize,
        ns1:PdNanoparticleDiameter,
        ns1:PtParticleSize ;
    ns1:usesInstrument ns1:TEMInstrument .

ns1:TransmissionLineModelAnalysis a ns1:Measurement ;
    rdfs:label "Transmission Line Model Analysis"@en ;
    dcterms:description "Analysis method to extract proton resistance and Cdl from impedance spectra."@en ;

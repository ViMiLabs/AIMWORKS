        "ATR-IR"@en,
        "ATR–FTIR"@en,
        "FTIR"@en,
        "attenuated total reflectance FTIR"@en ;
    skos:prefLabel "ATRFTIR Measurement"@en .

ns1:AcceleratedStressTestVoltageCycling a ns1:Manufacturing ;
    rdfs:label "Accelerated Stress Test Voltage Cycling"@en ;
    dcterms:description "Accelerated stress test: voltage cycling between 0.6–0.95 V for 30,000 cycles at controlled RH_AST."@en ;
    skos:altLabel "0.6 V"@en,
        "0.60 V"@en,
        "0.95 V"@en,
        "000 cycles"@en,
        "1.0 V"@en,
        "3 s"@en,
        "30"@en,
        "30k potential cycles"@en,
        "50 mV/s"@en,
        "80°C"@en,
        "AST"@en,
        "DOE protocol potential cycling"@en,
        "DoE protocol"@en,
        "RH_AST"@en,
        "accelerated degradation protocol (ADP)"@en,
        "accelerated stress test"@en,
        "accelerated stress testing"@en,
        "durability cycling"@en,
        "durability test"@en,
        "half-wave potential difference"@en,
        "potential cycles"@en,
        "potential cycling"@en,
        "start-stop cycling simulation"@en,
        "voltage cycling"@en ;
    skos:prefLabel "Accelerated Stress Test Voltage Cycling"@en ;
    ns1:hasInputMaterial <https://w3id.org/emmo/domain/pemfc#EMMO_099d5163_117a_4176_ba48_af54a61c4c8d> ;
    ns1:hasParameter ns1:DwellTime,
        ns1:LowerPotentialLimit,
        ns1:NumberOfCycles,
        ns1:OperatingTemperature,
        ns1:PotentialRampTime,
        ns1:PotentialWindow,
        ns1:RelativeHumidity,
        ns1:RelativeHumidityAST,
        ns1:ScanRate,
        ns1:Temperature,
        ns1:UpperPotentialLimit ;
    ns1:measures ns1:HalfWavePotentialShiftRelativeToNafion ;
    ns1:usesInstrument ns1:FuelCellTestCell,
        ns1:FuelCellTestStation .

ns1:AcidBaseTitrationMeasurement a ns1:Measurement ;
    rdfs:label "Acid Base Titration Measurement"@en ;
    dcterms:description "Acid-base titration used to determine phosphoric-acid doping level (ADL)."@en ;
    skos:altLabel "DIN EN ISO 660"@en,
        "acid value"@en,
        "acid value determination"@en,
        "acid-base titration"@en,
        "acidity"@en,
        "methyl orange indicator"@en ;
    skos:prefLabel "Acid Base Titration Measurement"@en ;
    ns1:hasInputMaterial ns1:CastorOil,
        ns1:SoybeanOil ;
    ns1:measures ns1:AcidDopingLevel,
        ns1:AcidValue .

ns1:AcidEtchingProcess a ns1:Manufacturing ;
    rdfs:label "Acid Etching Process"@en ;
    dcterms:description "Acid washing/etching step to remove Fe species (6 M HCl, repeated)."@en ;
    skos:altLabel "HCl etching"@en,
        "acid etching"@en ;
    skos:prefLabel "Acid Etching Process"@en ;
    ns1:hasInputMaterial ns1:HydrochloricAcid_2 ;
    ns1:hasParameter ns1:AcidEtchingRepetitions,
        ns1:HydrochloricAcidConcentration .

ns1:AcidLeachingProcess a ns1:Manufacturing ;
    rdfs:label "Acid Leaching Process"@en ;
    dcterms:description "Process to generate silica nanosheets from vermiculite by acid treatment."@en ;
    skos:altLabel "HCl treatment"@en,
        "acid leaching"@en,
        "acid–leaching method"@en,
        "oxalic acid leaching"@en ;
    skos:prefLabel "Acid Leaching Process"@en ;
    ns1:hasInputMaterial ns1:SteamActivatedFeNCCatalyst,
        ns1:Vermiculite ;
    ns1:hasOutputMaterial ns1:AcidLeachedSteamActivatedFeNCCatalyst,
        ns1:SilicaNanosheet .

ns1:AdhesionTapeTestMeasurement a ns1:Measurement ;

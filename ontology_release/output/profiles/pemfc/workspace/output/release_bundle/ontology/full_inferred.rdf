  <rdf:Description rdf:about="https://w3id.org/h2kg/hydrogen-ontology#CoReductionProcess">
    <skos:altLabel xml:lang="en">co-reduction</skos:altLabel>
    <skos:altLabel xml:lang="en">oxide reduction</skos:altLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
    <rdf:type rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Manufacturing"/>
    <skos:definition xml:lang="en">A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Co Reduction Process.</skos:definition>
    <dcterms:description xml:lang="en">Hydrogen reduction of blended oxides (Fe2O3+NiO+MoO3) to metals, enabling subsequent alloy formation.</dcterms:description>
    <rdfs:comment xml:lang="en">A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Co Reduction Process.</rdfs:comment>
    <skos:prefLabel xml:lang="en">Co Reduction Process</skos:prefLabel>
    <rdfs:label xml:lang="en">Co Reduction Process</rdfs:label>
  </rdf:Description>

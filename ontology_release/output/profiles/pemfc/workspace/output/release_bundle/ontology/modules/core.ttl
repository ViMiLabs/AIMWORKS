ns2:Agent a owl:Class ;
    rdfs:label "Agent"@en ;
    rdfs:comment "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Agent."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    rdfs:subClassOf prov:Agent ;
    owl:equivalentClass prov:Agent ;
    skos:definition "A class in the H2KG PEMFC Catalyst Layer Application Ontology representing Agent."@en .


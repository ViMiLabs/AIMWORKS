ns1:CatalyzedDiffusionMediumMethod a ns1:Manufacturing ;
    rdfs:label "Catalyzed Diffusion Medium Method"@en ;
    dcterms:description "IRI: (proposed_new) | description: MEA fabrication approach where catalyst layer is deposited into/onto diffusion medium/MPL instead of directly onto membrane."@en ;

    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Annealing Duration."@en ;
    skos:prefLabel "Annealing Duration"@en ;
    ns1:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_AnnealingDuration_QV> .

ns1:AnnealingTemperature a ns1:Parameter ;

ns1:AtomicLayerDeposition a ns1:Manufacturing ;
    rdfs:label "Atomic Layer Deposition"@en ;
    dcterms:description "Pt deposition process used to synthesize Pt/NbB2 catalyst (MeCpMe3Pt precursor)."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Atomic Layer Deposition."@en ;

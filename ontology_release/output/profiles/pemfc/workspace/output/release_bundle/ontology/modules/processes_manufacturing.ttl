ns1:AcidDoping a ns1:Manufacturing ;
    rdfs:label "Acid Doping"@en ;
    dcterms:description "Process of doping cross-linked PAA/PVA films by immersion in sulfuric acid solution to tune ionic strength."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Acid Doping."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "H3PO4 immersion"@en,
        "phosphoric acid doping"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Acid Doping."@en ;
    skos:prefLabel "Acid Doping"@en .

ns1:AcidTreatmentOfCCM a ns1:Manufacturing ;
    rdfs:label "Acid Treatment Of CCM"@en ;
    dcterms:description "proposed_definition=Post-fabrication acid treatment / washing of the catalyst-coated membrane (CCM) to remove leached metal ions (e.g., Ni2+) and improve mass transport.; Mentioned as improving H2/air performance and low-RH performance (Fig. 4)."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Acid Treatment Of CCM."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "acid-treated CCM"@en,
        "acid-washing"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Acid Treatment Of CCM."@en ;
    skos:prefLabel "Acid Treatment Of CCM"@en ;
    ns1:hasInputMaterial ns1:CatalystCoatedMembrane .

ns1:AmineHydrolysisProcess a ns1:Manufacturing ;
    rdfs:label "Amine Hydrolysis Process"@en ;
    dcterms:description "Amine hydrolysis step (with triethylamine) used to form MS@NiFeO nanohybrids."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Amine Hydrolysis Process."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "TEA/EG"@en,
        "amine hydrolysis"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Amine Hydrolysis Process."@en ;
    skos:prefLabel "Amine Hydrolysis Process"@en ;
    ns1:hasInputMaterial ns1:MoS2Nanosheets ;
    ns1:hasOutputMaterial ns1:MoS2NiFe2O4Nanohybrid .

ns1:AnnealingDuration a ns1:Parameter ;
    rdfs:label "Annealing Duration"@en ;
    dcterms:description "Duration of Pt(111) annealing step during surface preparation (1 h)."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Annealing Duration."@en ;

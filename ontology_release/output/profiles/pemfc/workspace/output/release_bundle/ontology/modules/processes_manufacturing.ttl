    ns1:hasOutputMaterial ns1:PtOnNbB2Catalyst .

ns1:BreakTimeBetweenSprayCycles a ns1:Parameter ;
    rdfs:label "Break Time Between Spray Cycles"@en ;
    dcterms:description "label_human: BreakTimeBetweenSprayCycles | description: Rest time between spray-pass series to allow solvent evaporation (reported 10 s)."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Break Time Between Spray Cycles."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;

<https://w3id.org/h2kg/hydrogen-ontology> a owl:Ontology ;
    dcterms:abstract "A release-ready, FAIR-oriented, EMMO-aligned application ontology for PEMFC catalyst-layer experiments and associated provenance-aware resources."@en ;
    dcterms:contributor "AIMWORKS Ontology Engineering Team"@en ;
    dcterms:created "2026-03-12"^^xsd:date ;
    dcterms:creator "Electrochemistry Research Group",
        "Electrochemistry Research Group"@en ;
    dcterms:description "Ontology for representing low-Pt PEM fuel-cell cathode catalyst layer experiments, focusing on ionomer/solvent effects on ECSA, high-frequency resistance, and oxygen-transport metrics over realistic operating conditions." ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:modified "2026-03-13" ;
    dcterms:source <https://w3id.org/h2kg/hydrogen-ontology> ;
    dcterms:title "Hydrogen Experiments Ontology – Low-Pt PEMFC Cathode Catalyst Layers" ;
    vann:preferredNamespacePrefix "h2kg" ;
    vann:preferredNamespaceUri ns11: ;
    owl:versionIRI <https://w3id.org/h2kg/hydrogen-ontology/releases/2026.3.0> ;
    owl:versionInfo "Generated on 2025-12-07 10:58:11" .

[] a ns11:DataPoint ;
    ns11:hasQuantityValue [ a ns2:QuantityValue ;
            ns2:quantityKind <http://qudt.org/vocab/quantitykind/AreaPerMass> ;
            ns2:unit <http://qudt.org/vocab/unit/M2-PER-GM> ] ;
    ns11:normalizedTo ns11:CatalystMass ;
    ns11:ofProperty ns11:ElectrochemicallyActiveSurfaceArea .

[] a ns11:DataPoint ;
    ns11:hasQuantityValue [ a ns2:QuantityValue ;
            ns2:quantityKind <http://qudt.org/vocab/quantitykind/Resistance> ;
            ns2:unit <http://qudt.org/vocab/unit/OHM> ] ;
    ns11:ofProperty ns11:OhmicResistance .


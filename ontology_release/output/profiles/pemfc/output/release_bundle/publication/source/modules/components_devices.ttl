@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ns1: <https://w3id.org/h2kg/hydrogen-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

ns1:AcidUptakeMeasurement a ns1:Measurement ;
    rdfs:label "Acid Uptake Measurement"@en ;
    dcterms:description "Measurement of phosphoric acid uptake and acid doping level (ADL) by mass difference."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Acid Uptake Measurement."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "PA uptake measurement"@en ;
    skos:closeMatch <https://w3id.org/emmo/domain/electrochemistry#electrochemistry_f4ce4df2_d7e6_470f_8eab_3a911adaaf0f> ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Acid Uptake Measurement."@en ;
    skos:prefLabel "Acid Uptake Measurement"@en ;
    ns1:measures ns1:AcidDopingLevel,
        ns1:AcidUptakeWeightPercent .

ns1:AdhesionTapeTestMeasurement a ns1:Measurement ;
    rdfs:label "Adhesion Tape Test Measurement"@en ;
    dcterms:description "Qualitative adhesion evaluation of Cu patterns on PET via adhesive tape test."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Adhesion Tape Test Measurement."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "ASTM D-3359"@en,
        "tape peel test"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Adhesion Tape Test Measurement."@en ;
    skos:prefLabel "Adhesion Tape Test Measurement"@en ;
    ns1:hasInputMaterial ns1:CopperFilm,
        ns1:PETSubstrate .

ns1:AnsysFluentFuelCellModule a ns1:Instrument ;
    rdfs:label "Ansys Fluent Fuel Cell Module"@en ;
    dcterms:description "desc=CFD software module used to solve PEMFC governing equations and simulate polarization behavior."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Ansys Fluent Fuel Cell Module."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "Ansys Fluent 15.0"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Ansys Fluent Fuel Cell Module."@en ;
    skos:prefLabel "Ansys Fluent Fuel Cell Module"@en .

ns1:ArchimedesDensityMeasurement a ns1:Measurement ;
    rdfs:label "Archimedes Density Measurement"@en ;
    dcterms:description "Bulk density measurement of printed, pyrolyzed parts by Archimedes method."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Archimedes Density Measurement."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "ASTM C373-88"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Archimedes Density Measurement."@en ;
    skos:prefLabel "Archimedes Density Measurement"@en ;
    ns1:measures ns1:BulkDensity .

ns1:AssemblyTorque a ns1:Parameter ;
    rdfs:label "Assembly Torque"@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Assembly Torque."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "4 N m"@en,
        "40 lb-in"@en,
        "5 N m"@en,
        "clamping torque"@en,
        "torque"@en,
        "torque 40 lb-in"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Assembly Torque."@en ;
    skos:prefLabel "Assembly Torque"@en ;
    ns1:hasQuantityValue [ ] .

ns1:CVScanRateMeasurement a ns1:Parameter ;
    rdfs:label "CV Scan Rate Measurement"@en ;
    dcterms:description "CV measurement scan rate 20 mV/s for 10 cycles."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing CV Scan Rate Measurement."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "CV scan rate"@en,
        "scan rate"@en,
        "slew rate"@en ;
    skos:closeMatch <https://w3id.org/emmo/domain/electrochemistry#electrochemistry_f4ce4df2_d7e6_470f_8eab_3a911adaaf0f> ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing CV Scan Rate Measurement."@en ;
    skos:prefLabel "CV Scan Rate Measurement"@en ;
    ns1:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_CVScanRateMeasurement_QV> .

ns1:CapillaryPressureInMembrane a ns1:Property ;
    rdfs:label "Capillary Pressure In Membrane"@en ;
    dcterms:description "proposed_new_term. paper_context: Capillary pressure (mbar) built up in membrane inferred from operando crack saturation vs ex situ filling curves."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Capillary Pressure In Membrane."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "acid pressure"@en,
        "acid pressure in membrane"@en,
        "capillary pressure"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Capillary Pressure In Membrane."@en ;
    skos:prefLabel "Capillary Pressure In Membrane"@en ;
    ns1:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_CapillaryPressureInMembrane_QV> .

ns1:CarbonFeltElectrode a ns1:Matter ;
    rdfs:label "Carbon Felt Electrode"@en ;
    dcterms:description "Carbon felt substrate used as both anode and cathode electrode material in the MFC."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Carbon Felt Electrode."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "Panex35 carbon felt"@en,
        "carbon felt"@en,
        "graphite felt"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Carbon Felt Electrode."@en ;
    skos:prefLabel "Carbon Felt Electrode"@en .

ns1:CatalystLayerAcidLoadingDetermination a ns1:Measurement ;
    rdfs:label "Catalyst Layer Acid Loading Determination"@en ;
    dcterms:description "CL H3PO4 loading estimated from mass difference before/after doping; not found in ontology."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Catalyst Layer Acid Loading Determination."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "H3PO4 in CL"@en,
        "H3PO4 loading estimated from weight difference"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Catalyst Layer Acid Loading Determination."@en ;
    skos:prefLabel "Catalyst Layer Acid Loading Determination"@en ;
    ns1:hasQuantityValue ns1:_CatalystLayerAcidLoadingDetermination_QV ;
    ns1:measures ns1:PhosphoricAcidLoading .

ns1:CatalystLayerConductivityExponentB a ns1:Parameter ;
    rdfs:label "Catalyst Layer Conductivity Exponent B"@en ;
    dcterms:description "Label: Catalyst Layer Conductivity Exponent B. In this paper: Exponent B in σ_eff,CL(a_H2O)=A·exp(B·a_H2O) (B=3.0)."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Catalyst Layer Conductivity Exponent B."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "B"@en,
        "CL conductivity exponent B"@en ;
    skos:closeMatch <http://qudt.org/vocab/quantitykind/Conductivity> ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Catalyst Layer Conductivity Exponent B."@en ;
    skos:prefLabel "Catalyst Layer Conductivity Exponent B"@en ;
    ns1:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_CatalystLayerConductivityExponentB_QV> .

ns1:CatalystLayerConductivityPrefactorA a ns1:Parameter ;
    rdfs:label "Catalyst Layer Conductivity Prefactor A"@en ;
    dcterms:description "Label: Catalyst Layer Conductivity Prefactor A. In this paper: Prefactor A in σ_eff,CL(a_H2O)=A·exp(B·a_H2O), with values differing by drying method (FD/VD: 1.0×10−2 S m−1; OD: 0.80×10−2 S m−1)."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Catalyst Layer Conductivity Prefactor A."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "CL conductivity A"@en ;
    skos:closeMatch <http://qudt.org/vocab/quantitykind/Conductivity> ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Catalyst Layer Conductivity Prefactor A."@en ;
    skos:prefLabel "Catalyst Layer Conductivity Prefactor A"@en ;
    ns1:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_CatalystLayerConductivityPrefactorA_QV> .


ns2:ACAmplitude a ns2:Parameter ;
    rdfs:label "ACAmplitude"@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing ACAmplitude."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "0.27 mV"@en,
        "10 mV"@en,
        "10 mV amplitude"@en,
        "10 mV perturbation"@en,
        "10% of applied current"@en,
        "3 mV"@en,
        "3 mV AC amplitude"@en,
        "3.5 mV perturbation"@en,
        "5 mV amplitude"@en,
        "AC amplitude"@en,
        "AC perturbation"@en,
        "perturbation amplitude"@en,
        "voltage perturbation"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing ACAmplitude."@en ;
    skos:prefLabel "ACAmplitude"@en ;
    ns2:hasQuantityValue [ a ns1:QuantityValue ;
            ns1:quantityKind <http://qudt.org/vocab/quantitykind/ElectricPotential>,
                <http://qudt.org/vocab/quantitykind/ElectricPotentialAmplitude>,
                <http://qudt.org/vocab/quantitykind/ElectricPotentialDifference>,
                <http://qudt.org/vocab/quantitykind/RelativeAmplitude>,
                <http://qudt.org/vocab/quantitykind/Voltage>,
                <http://qudt.org/vocab/quantitykind/VoltageAmplitude> ;
            ns1:unit <http://qudt.org/vocab/unit/MilliV>,
                <http://qudt.org/vocab/unit/PERCENT> ] .

ns2:ACInputAmplitude a ns2:Parameter ;

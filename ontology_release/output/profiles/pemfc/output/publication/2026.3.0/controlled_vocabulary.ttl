    skos:prefLabel "AC Input Amplitude"@en ;
    ns2:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/output/profiles/pemfc/workspace/input/_ACInputAmplitude_QV> .


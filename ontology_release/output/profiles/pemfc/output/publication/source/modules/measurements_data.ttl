@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ns1: <https://w3id.org/h2kg/hydrogen-ontology#> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

ns1:ACAmplitude a ns1:Parameter ;
    rdfs:label "ACAmplitude"@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing ACAmplitude."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "AC amplitude"@en,
        "AC perturbation"@en,
        "perturbation amplitude"@en,
        "voltage perturbation"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing ACAmplitude."@en ;
    skos:prefLabel "ACAmplitude"@en ;
    ns1:hasQuantityValue [ ] .

ns1:ACInputAmplitude a ns1:Parameter ;
    rdfs:label "AC Input Amplitude"@en ;
    dcterms:description "Amplitude of the AC sinusoidal signal used to read impedance for strain sensing (not the small-signal EIS perturbation amplitude)."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing AC Input Amplitude."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing AC Input Amplitude."@en ;
    skos:prefLabel "AC Input Amplitude"@en ;
    ns1:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_ACInputAmplitude_QV> .

ns1:AbsorptionPeakWavelength a ns1:Property ;
    rdfs:label "Absorption Peak Wavelength"@en ;
    dcterms:description "Wavelength of UV–Vis absorption maxima (e.g., porphyrin Soret/Q bands, peaks observed in solid-state/solution)."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Absorption Peak Wavelength."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "Q band"@en,
        "Soret band"@en,
        "absorption peak"@en,
        "λmax"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Absorption Peak Wavelength."@en ;
    skos:prefLabel "Absorption Peak Wavelength"@en ;
    ns1:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_AbsorptionPeakWavelength_QV> .

ns1:AcceleratingVoltage a ns1:Parameter ;
    rdfs:label "Accelerating Voltage"@en ;
    dcterms:description "TEM accelerating voltage."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Accelerating Voltage."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "SEM operating voltage"@en,
        "TEM accelerating voltage"@en,
        "acceleration voltage"@en,
        "tube voltage"@en ;
    skos:closeMatch <http://qudt.org/vocab/quantitykind/ElectricPotential> ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Accelerating Voltage."@en ;
    skos:prefLabel "Accelerating Voltage"@en ;
    ns1:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_AcceleratingVoltage_QV>,
        <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_AcceleratingVoltage_QV_2> .

ns1:AcidDopingLevel a ns1:Property ;
    rdfs:label "Acid Doping Level"@en ;
    dcterms:description "Phosphoric-acid doping level of PBI/PIM membrane (mol PA per mol repeat unit)."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Acid Doping Level."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "ADL"@en,
        "H3PO4 doping level"@en,
        "PA-doping level"@en,
        "PA_dop"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Acid Doping Level."@en ;
    skos:prefLabel "Acid Doping Level"@en ;
    ns1:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_AcidDopingLevel_QV> .

ns1:AcidEtchingRepetitions a ns1:Parameter ;
    rdfs:label "Acid Etching Repetitions"@en ;
    dcterms:description "Number of HCl etching repetitions."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Acid Etching Repetitions."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "etch repetitions"@en,
        "immersed in HCl three times"@en ;

    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Plasticizer ATBC Mass."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "ATBC mass"@en,
        "Plasticizer (ATBC)"@en,
        "Plasticizer (ATBC) 3.5g"@en ;

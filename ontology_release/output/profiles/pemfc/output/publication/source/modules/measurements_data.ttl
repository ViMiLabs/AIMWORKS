    skos:prefLabel "Acid Uptake Weight Percent"@en ;
    ns1:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_AcidUptakeWeightPercent_QV> .

ns1:AcousticFrequency a ns1:Parameter ;
    rdfs:label "Acoustic Frequency"@en ;
    dcterms:description "Jetting actuation frequency used for inkjet printing."@en ;

    dcterms:description "Pressure-dependent component (molecular diffusion in large pores/diffusion media)."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Pressure Dependent Gas Diffusion Resistance."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "RMD"@en,
        "R_MD"@en,
        "R_P"@en,
        "R_PD"@en,
        "Res. slope"@en,
        "dep"@en,
        "molecular diffusion part"@en,
        "molecular diffusion resistance"@en,
        "pressure dependent resistance"@en,
        "pressure dependent resistance part"@en,
        "pressure-dependent O2 resistance"@en ;
    skos:closeMatch <http://qudt.org/vocab/quantitykind/Resistance> ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Pressure Dependent Gas Diffusion Resistance."@en ;
    skos:prefLabel "Pressure Dependent Gas Diffusion Resistance"@en ;
    ns1:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_PressureDependentGasDiffusionResistance_QV> .


    dcterms:description "Light source used for visible-light irradiation during photodegradation/self-cleaning tests (paper mentions 300 W lamp)."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Visible Light Lamp."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "300 W lamp"@en,
        "visible-light irradiation source"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Visible Light Lamp."@en ;
    skos:prefLabel "Visible Light Lamp"@en ;
    ns1:hasQuantityValue ns1:_VisibleLightLamp_QV .

ns1:VoltageSensor a ns1:Instrument ;
    rdfs:label "Voltage Sensor"@en ;
    dcterms:description "Voltage sensing hardware used to record fuel cell voltage during aging tests."@en ;

    skos:prefLabel "Acid Etching Repetitions"@en ;
    ns1:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_AcidEtchingRepetitions_QV> .

ns1:AcidMassUptakeRatio a ns1:Property ;
    rdfs:label "Acid Mass Uptake Ratio"@en ;
    dcterms:description "Fractional mass increase upon acid doping measured by QCM (Δm/m0); used to estimate acid uptake."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Acid Mass Uptake Ratio."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "fractional mass increase"@en,
        "mass uptake ratio"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Acid Mass Uptake Ratio."@en ;
    skos:prefLabel "Acid Mass Uptake Ratio"@en ;
    ns1:hasQuantityValue <file:///C:/MARJAN/H2KG/AIMWORKS/ontology_release/_AcidMassUptakeRatio_QV> .

ns1:AcidUptakeDataset a ns1:Data ;
    rdfs:label "Acid Uptake Dataset"@en ;
    dcterms:description "Dataset of QCM-measured mass uptake and derived proton concentration vs dopant concentration."@en ;
    rdfs:comment "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Acid Uptake Dataset."@en ;
    rdfs:isDefinedBy <https://w3id.org/h2kg/hydrogen-ontology> ;
    skos:altLabel "QCM mass uptake"@en,
        "acid uptake data"@en ;
    skos:definition "A curated controlled term in the H2KG PEMFC Catalyst Layer Application Ontology representing Acid Uptake Dataset."@en ;
    skos:prefLabel "Acid Uptake Dataset"@en .

ns1:AcidUptakeWeightPercent a ns1:Property ;
    rdfs:label "Acid Uptake Weight Percent"@en ;

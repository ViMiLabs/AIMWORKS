<https://w3id.org/h2kg/hydrogen-ontology> a owl:Ontology ;
    dcterms:abstract "A release-ready, FAIR-oriented, EMMO-aligned application ontology for PEMFC catalyst-layer experiments and associated provenance-aware resources."@en ;
    dcterms:contributor "Institute of Energy Technologies (IET), Theory and Computation of Energy Materials (IET-3), Forschungszentrum Juelich GmbH, 52428 Juelich, Germany",
        "AIMWORKS Ontology Engineering Team"@en ;
    dcterms:created "2026-03-12"^^xsd:date ;
    dcterms:creator "Electrochemistry Research Group",
        "Electrochemistry Research Group"@en ;
    dcterms:description "Ontology for representing proton exchange membrane water electrolysis materials, components, devices, processes, measurements, and experiments." ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:modified "2026-03-18" ;
    dcterms:publisher "Forschungszentrum Juelich GmbH" ;
    dcterms:references <https://w3id.org/battinfo>,
        <https://w3id.org/emmo>,
        <https://w3id.org/emmo/domain/characterisation-methodology/chameo#>,
        <https://w3id.org/emmo/domain/coating#>,
        <https://w3id.org/emmo/domain/electrochemistry>,
        <https://w3id.org/emmo/domain/equivalent-circuit-model#>,
        <https://w3id.org/emmo/domain/manufacturing#>,
        <https://w3id.org/emmo/domain/microscopy#> ;
    dcterms:source <https://w3id.org/h2kg/hydrogen-ontology> ;
    dcterms:title "H2KG: Ontology for Proton Exchange Membrane Water Electrolysis Materials, Components, and Experiments" ;
    vann:preferredNamespacePrefix "h2kg" ;
    vann:preferredNamespaceUri ns1: ;
    rdfs:seeAlso <https://www.fz-juelich.de/en/iet/iet-3/divisions-1/artificial-material-intelligence> ;
    owl:imports <https://w3id.org/emmo>,
        <https://w3id.org/emmo/domain/characterisation-methodology/chameo#>,
        <https://w3id.org/emmo/domain/coating#>,
        <https://w3id.org/emmo/domain/electrochemistry>,
        <https://w3id.org/emmo/domain/equivalent-circuit-model#>,
        <https://w3id.org/emmo/domain/manufacturing#>,
        <https://w3id.org/emmo/domain/microscopy#> ;
    owl:versionIRI <https://w3id.org/h2kg/hydrogen-ontology/releases/2026.3.0> ;
    owl:versionInfo "Generated on 2025-11-28 16:12:13" ;
    foaf:homepage <https://www.fz-juelich.de/en/iet/iet-3/divisions-1/artificial-material-intelligence> .

[] a ns1:DataPoint ;
    ns1:hasQuantityValue [ a ns2:QuantityValue ;
            ns2:quantityKind <http://qudt.org/vocab/quantitykind/ElectricCurrentDensity> ;
            ns2:unit <http://qudt.org/vocab/unit/MilliA-PER-CentiM2> ] ;
    ns1:normalizedTo ns1:GeometricArea ;
    ns1:ofProperty ns1:ExchangeCurrentDensity .

[] a ns1:DataPoint ;
    ns1:hasQuantityValue [ a ns2:QuantityValue ;
            ns2:quantityKind <http://qudt.org/vocab/quantitykind/ElectricCurrentPerMass> ;
            ns2:unit <http://qudt.org/vocab/unit/A-PER-GM> ] ;
    ns1:normalizedTo ns1:CatalystMass ;
    ns1:ofProperty ns1:MassActivity .

[] a ns1:DataPoint ;
    ns1:hasQuantityValue [ a ns2:QuantityValue ;
            ns2:quantityKind <http://qudt.org/vocab/quantitykind/ElectricPotential> ;
            ns2:unit <http://qudt.org/vocab/unit/MilliV> ] ;
    ns1:ofProperty ns1:Overpotential .

[] a ns1:DataPoint ;
    ns1:hasQuantityValue [ a ns2:QuantityValue ;
            ns2:quantityKind <http://qudt.org/vocab/quantitykind/Resistance> ;
            ns2:unit <http://qudt.org/vocab/unit/OHM> ] ;
    ns1:ofProperty ns1:ChargeTransferResistance .

[] a ns1:DataPoint ;
    ns1:hasQuantityValue [ a ns2:QuantityValue ;
            ns2:quantityKind <http://qudt.org/vocab/quantitykind/Capacitance> ;
            ns2:unit <http://qudt.org/vocab/unit/FARAD-PER-CentiM2> ] ;
    ns1:ofProperty ns1:DoubleLayerCapacitance .


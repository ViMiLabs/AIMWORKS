    "http://purl.org/dc/terms/abstract": [
      {
        "@language": "en",
        "@value": "A release-ready, FAIR-oriented, EMMO-aligned application ontology for PEMFC catalyst-layer experiments and associated provenance-aware resources."
      }
    ],
    "http://purl.org/dc/terms/contributor": [
      {
        "@language": "en",
        "@value": "AIMWORKS Ontology Engineering Team"
      }
    ],
    "http://purl.org/dc/terms/created": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-03-12"
      }
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@value": "Electrochemistry Research Group"
      },
      {
        "@language": "en",
        "@value": "Electrochemistry Research Group"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "Ontology for representing low-Pt PEM fuel-cell cathode catalyst layer experiments, focusing on ionomer/solvent effects on ECSA, high-frequency resistance, and oxygen-transport metrics over realistic operating conditions."
      }
    ],
    "http://purl.org/dc/terms/license": [
      {
        "@id": "https://creativecommons.org/licenses/by/4.0/"
      }
    ],
    "http://purl.org/dc/terms/modified": [

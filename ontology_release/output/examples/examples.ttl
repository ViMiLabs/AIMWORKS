  h2kg:hasInputMaterial h2kg:DLPElastomerResin, h2kg:DLPPlasticResin, h2kg:PhotocurableDIWInk, h2kg:LiquidCrystalElastomerInk, h2kg:ConductiveSilverInk .

h2kg:ParticleSizeMeasurement
  a h2kg:Measurement ;
  skos:prefLabel "Particle Size Measurement"@en ;
  rdfs:label "Particle Size Measurement"@en ;
  skos:altLabel "particle size analyzer measurement"@en, "laser diffraction particle size analysis"@en, "particle size"@en ;

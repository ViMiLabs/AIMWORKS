h2kg:CarbonBlackAggregateStructureSimulation
  a h2kg:Measurement ;
  skos:prefLabel "Carbon Black Aggregate Structure Simulation"@en ;
  rdfs:label "Carbon Black Aggregate Structure Simulation"@en ;
  skos:altLabel "CB aggregate structure simulation"@en ;
  dcterms:description "Simulation step that reconstructs 3D carbon black aggregate morphology using probability-density placement and surface roughness fitting (validated vs size/SSA/pore volume)."@en ;
  h2kg:hasInputMaterial h2kg:VulcanXC72RCarbonBlack ;
  h2kg:hasParameter h2kg:CarbonBlackPrimaryParticlesPerAggregate, h2kg:ProbabilityDensityMorphologyParameterK, h2kg:VoxelSize ;
  h2kg:measures h2kg:AgglomerateDiameter, h2kg:CarbonBlackAggregateAnisotropyRatio, h2kg:BETSurfaceAreaNitrogen, h2kg:MicroporeVolume, h2kg:MesoporeVolume ;
  h2kg:hasOutputData h2kg:AgglomerateSizeDistributionDataset .

h2kg:CatalystLayerMicrostructureSimulation
  a h2kg:Measurement ;
  skos:prefLabel "Catalyst Layer Microstructure Simulation"@en ;
  rdfs:label "Catalyst Layer Microstructure Simulation"@en ;
  skos:altLabel "catalyst layer simulation"@en ;
  dcterms:description "Simulation that packs reconstructed CB aggregates into a 3D catalyst layer, applies ionomer coating model, and computes ionomer connectivity/tortuosity and relative proton conductivity."@en ;
  h2kg:hasInputMaterial holy:CatalystLayer ;
  h2kg:hasParameter h2kg:CarbonBlackVolumeFraction, h2kg:IonomerToCarbonRatio ;
  h2kg:measures h2kg:RelativeProtonConductivity, h2kg:RelativeProtonConductivityExponentRICHigh, h2kg:RelativeProtonConductivityExponentVCB, h2kg:RelativeProtonConductivityThresholdRIC, h2kg:RelativeProtonConductivityCoefficientLowRIC, h2kg:RelativeProtonConductivityExponentRICLow ;
  h2kg:hasOutputData h2kg:ConductivityDataset .


h2kg:PhotocatalyticDegradationMeasurement
  a h2kg:Measurement ;
  skos:prefLabel "Photocatalytic Degradation Measurement"@en ;
  rdfs:label "Photocatalytic Degradation Measurement"@en ;
  skos:altLabel "photocatalytic degradation"@en ;
  dcterms:description "Photocatalytic activity measurement tracking pollutant (RhB) degradation under visible light over time."@en ;
  h2kg:measures h2kg:PhotodegradationEfficiency, h2kg:PseudoFirstOrderRateConstant ;
  h2kg:hasInputMaterial h2kg:RhodamineB, h2kg:HydrogenPeroxide, h2kg:MethyleneBlue ;
  h2kg:hasParameter h2kg:IrradiationTime, h2kg:LightSourcePower, h2kg:WavelengthCutoff, h2kg:LampToSampleDistance, h2kg:DyeConcentration, h2kg:SolutionVolume, h2kg:HydrogenPeroxideVolume, h2kg:NumberOfCycles ;
  h2kg:usesInstrument h2kg:XenonLamp, h2kg:UVVisNIRSpectrophotometer, h2kg:VisibleLightLamp, h2kg:UVVisibleSpectrophotometer ;
  h2kg:hasOutputData h2kg:PhotodegradationDataset .

h2kg:ElectronSpinResonanceSpectroscopyMeasurement
  a h2kg:Measurement ;
  skos:prefLabel "Electron Spin Resonance Spectroscopy Measurement"@en ;
  rdfs:label "Electron Spin Resonance Spectroscopy Measurement"@en ;
  dcterms:description "ESR spectroscopy used to detect reactive oxygen species (•OH, •O2−) via spin-trap (DMPO)."@en ;
  h2kg:usesInstrument h2kg:ESRSpectrometer .


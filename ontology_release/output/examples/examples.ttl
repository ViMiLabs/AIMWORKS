h2kg:PorosityMeasurement
  a h2kg:Measurement ;
  skos:prefLabel "Porosity Measurement"@en ;
  rdfs:label "Porosity Measurement"@en ;
  skos:altLabel "pycnometer density and porosity calculation"@en, "porosity evaluation from FIB-SEM"@en, "porosity ε"@en ;
  dcterms:description "Determination of total and open porosity from bulk/apparent/true density (caliper/balance + helium pycnometry)."@en ;
  h2kg:measures h2kg:TotalPorosity, h2kg:OpenPorosity, h2kg:BulkDensity, h2kg:ApparentDensity, h2kg:TrueDensity, h2kg:CatalystLayerPorosity ;
  h2kg:usesInstrument h2kg:HeliumPycnometer, h2kg:DigitalCaliper, h2kg:DigitalBalance, h2kg:SEMInstrument ;
  h2kg:hasParameter h2kg:TrueDensity ;
  h2kg:hasInputMaterial h2kg:Carbonized3DPrintedCarbonMaterial, h2kg:CesiumFormateSolution, holy:CatalystLayer .

h2kg:CompressiveStrengthMeasurement
  a h2kg:Measurement ;
  skos:prefLabel "Compressive Strength Measurement"@en ;
  rdfs:label "Compressive Strength Measurement"@en ;
  skos:altLabel "compressive strength test"@en, "compressive stress-strain"@en ;
  dcterms:description "Mechanical testing under compression to determine compressive strength of printed lattices."@en ;
  h2kg:measures h2kg:CompressiveStrength, h2kg:YoungsModulus ;
  h2kg:usesInstrument h2kg:UniversalTestingMachine ;
  h2kg:hasParameter h2kg:CrossheadSpeed ;
  h2kg:hasInputMaterial h2kg:Carbonized3DPrintedCarbonMaterial, h2kg:SmartElastomericCellularFoam .


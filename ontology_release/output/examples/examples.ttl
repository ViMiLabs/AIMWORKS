  a h2kg:Parameter ;
  skos:prefLabel "Exchange Current Density"@en ;
  rdfs:label "Exchange Current Density"@en ;
  skos:altLabel "i_ref"@en, "i0"@en, "i_ef"@en ;
  dcterms:description "Reference exchange current density used in Butler–Volmer kinetics (Table 2)."@en ;
  h2kg:hasQuantityValue <_ExchangeCurrentDensity_QV> .

h2kg:ChargeTransferCoefficient
  a h2kg:Parameter ;
  skos:prefLabel "Charge Transfer Coefficient"@en ;
  rdfs:label "Charge Transfer Coefficient"@en ;
  skos:altLabel "alpha_c"@en, "α_c"@en, "electron transfer coefficient"@en ;
  dcterms:description "Charge-transfer coefficient used in Butler–Volmer kinetics (Table 2)."@en ;
  h2kg:hasQuantityValue <_ChargeTransferCoefficient_QV> .


  skos:altLabel "liquid nitrogen freezing method"@en, "LN_1–LN_4 treatment"@en ;
  dcterms:description "Cryogenic release step: liquid nitrogen scattered over MEA just before peeling decal substrate to improve transfer yield."@en .

h2kg:VacuumDrying

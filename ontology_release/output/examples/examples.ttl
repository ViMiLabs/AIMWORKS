  h2kg:hasOutputMaterial h2kg:PlatinumCoatedGlassSlide ;
  h2kg:hasInputMaterial h2kg:CarbonNanotubeForest, h2kg:Platinum ;
  h2kg:usesInstrument h2kg:SputterCoater .


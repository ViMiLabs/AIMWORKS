<_OxygenDiffusionCoefficientInIonomer_QV>
  a qudt:QuantityValue ;
  qudt:quantityKind quantitykind:DiffusionCoefficient .

<_HenrysCoefficient_QV>
  a qudt:QuantityValue ;
  qudt:quantityKind quantitykind:Dimensionless .

<_ExchangeCurrentDensity_QV>

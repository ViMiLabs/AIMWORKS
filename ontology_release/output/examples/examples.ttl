h2kg:DifferentialScanningCalorimetryMeasurement
  a h2kg:Measurement ;
  skos:prefLabel "Differential Scanning Calorimetry Measurement"@en ;
  rdfs:label "Differential Scanning Calorimetry Measurement"@en ;
  skos:altLabel "DSC"@en, "differential scanning calorimetry"@en ;
  dcterms:description "Thermal analysis measurement of exothermic/endothermic events during heating (25–400°C at 20°C/min)."@en, "Proposed new term. Thermal analysis used to observe β→α phase transition of Ag2Se (endothermic peak at ~134.5°C)."@en, "DSC (as part of TG–DSC) for thermal events in colloidal silica."@en ;
  h2kg:usesInstrument h2kg:DifferentialScanningCalorimeter, h2kg:DSCInstrument, h2kg:SynchronousThermalAnalyzer ;
  h2kg:measures h2kg:ThermalEventPeakTemperature, h2kg:PhaseTransitionTemperature ;
  h2kg:hasParameter h2kg:HeatingRate, h2kg:Temperature, h2kg:OxygenVolumeFraction ;
  h2kg:hasOutputData h2kg:ThermalAnalysisDataset .

h2kg:OpticalMicroscopyImagingMeasurement

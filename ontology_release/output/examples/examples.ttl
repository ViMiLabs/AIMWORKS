  rdfs:label "Oxygen Plasma Treatment"@en ;
  skos:altLabel "oxygen plasma"@en ;
  dcterms:description "Surface treatment of substrates (e.g., thermanox) with oxygen plasma to improve ink adhesion/wetting prior to coating/printing."@en ;
  h2kg:hasInputMaterial h2kg:ThermanoxSubstrate .


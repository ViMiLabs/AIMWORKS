h2kg:XRayComputedTomographyMeasurement
  a h2kg:Measurement ;
  skos:prefLabel "X Ray Computed Tomography Measurement"@en ;
  rdfs:label "X Ray Computed Tomography Measurement"@en ;
  skos:altLabel "x-ray computed tomography"@en, "X-ray tomography"@en, "X-ray CT"@en ;
  dcterms:description "X-ray computed tomography imaging used to quantify fiber orientation angles and internal defects."@en ;
  h2kg:usesInstrument h2kg:XRayCTInstrument, h2kg:XRayMicroscope ;

h2kg:DiscreteElementMethodPackingSimulation
  a h2kg:Measurement ;
  skos:prefLabel "Discrete Element Method Packing Simulation"@en ;
  rdfs:label "Discrete Element Method Packing Simulation"@en ;
  skos:altLabel "discrete element method"@en, "DEM"@en, "DEM simulation"@en ;
  dcterms:description "Computational reconstruction of CL geometry by DEM packing of multisphere carbon agglomerates during ink drying."@en ;
  h2kg:measures h2kg:CatalystLayerPorosity, h2kg:InterAgglomeratePoreSize, h2kg:CatalystLayerThickness, h2kg:MeanParticleSize ;
  h2kg:hasParameter h2kg:AgglomerateDiameter, h2kg:AgglomerateShape, h2kg:Viscosity, h2kg:ContactSpringCoefficient, h2kg:DEMTimeStep, h2kg:IonomerToCarbonRatio, h2kg:SolidContentFraction, h2kg:DielectricConstant, h2kg:CriticalDielectricConstant, h2kg:PolymerForceProportionalityConstant, h2kg:PolymerForceExponentialCoefficient, h2kg:NormalizedPolymerForceFactor, h2kg:LogNormalStandardDeviation, h2kg:SimulationTimeStepCount, h2kg:SimulationParticleCount, h2kg:HamakerConstant, h2kg:ZetaPotential, h2kg:DebyeLength, h2kg:IonomerEquivalentWeight, h2kg:IonicStrength, h2kg:Temperature ;
  h2kg:hasInputMaterial h2kg:CarbonSupport, h2kg:CatalystInk ;
  h2kg:hasOutputData h2kg:AgglomerateSizeDistributionDataset .

h2kg:IonomerCoatingSimulation
  a h2kg:Measurement ;
  skos:prefLabel "Ionomer Coating Simulation"@en ;
  rdfs:label "Ionomer Coating Simulation"@en ;
  skos:altLabel "ionomer coating"@en, "ionomer coating step"@en, "ionomer adsorption simulation"@en ;
  dcterms:description "Computational step that applies a constant-thickness ionomer film to carbon to meet a target I/C ratio."@en ;
  h2kg:hasParameter h2kg:IonomerToCarbonRatio, h2kg:IonomerEquivalentWeight, h2kg:AlcoholMassFractionInSolventMixture, h2kg:IonomerMassFraction, h2kg:Temperature, h2kg:CellPressure, h2kg:VoxelSize ;
  h2kg:measures h2kg:IonomerFilmThickness, h2kg:IonomerPatchSurfaceCoverage, h2kg:BackboneAttachmentMolarPercent, h2kg:IonomerCoverageLnCoefficient, h2kg:IonomerCoverageIntercept ;
  h2kg:hasInputMaterial h2kg:CarbonSupport, h2kg:PFSAIonomer, h2kg:Water, h2kg:Methanol, h2kg:GraphiteSheet, h2kg:GraphiteSheetWithCarboxylateGroups, h2kg:VulcanXC72RCarbonBlack ;
  h2kg:hasOutputMaterial h2kg:IonomerFilm ;
  h2kg:hasOutputData h2kg:CatalystInkStructureDataset .

h2kg:ElectrochemicalReactionSimulation
  a h2kg:Measurement ;
  skos:prefLabel "Electrochemical Reaction Simulation"@en ;
  rdfs:label "Electrochemical Reaction Simulation"@en ;
  skos:altLabel "mass transfer simulation"@en ;
  dcterms:description "3D electrochemical reaction + mass/charge transfer simulation on reconstructed geometry using upscaled transport properties."@en ;
  h2kg:measures h2kg:LimitingCurrentDensity, h2kg:PowerDensity, h2kg:Overpotential, h2kg:EffectiveOxygenDiffusionCoefficient, h2kg:EffectiveIonicConductivity ;
  h2kg:hasParameter h2kg:OxygenDiffusionCoefficientInIonomer, h2kg:OpenCircuitVoltage, h2kg:HenrysCoefficient, h2kg:ExchangeCurrentDensity, h2kg:ChargeTransferCoefficient, h2kg:GasDiffusionLayerThickness, h2kg:GasDiffusionLayerPorosity, h2kg:MembraneThickness, h2kg:CellPressure, h2kg:Temperature, h2kg:RelativeHumidity, h2kg:OxygenVolumeFraction, h2kg:ChannelToSpacerAreaRatio, h2kg:CatalystLayerThickness, h2kg:CatalystLayerPorosity, h2kg:MicroporousLayerPorosity, h2kg:MicroporousLayerPermeability, h2kg:PoreRadius, h2kg:CatalystLayerConductivityPrefactorA, h2kg:CatalystLayerConductivityExponentB, h2kg:IonomerFilmResistancePrefactorC, h2kg:IonomerFilmResistanceExponentD ;
  h2kg:hasInputMaterial h2kg:CathodeCatalystLayer, pemfc:EMMO_143d21b5_d044_4af3_a9f9_22928f2516c1, holy:Membrane, h2kg:Oxygen, h2kg:Water .


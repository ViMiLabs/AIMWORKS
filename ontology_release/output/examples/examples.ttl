  h2kg:hasInputMaterial h2kg:Solvent, h2kg:Isopropanol, h2kg:Ethanol, h2kg:Acetone, h2kg:EthyleneGlycol, h2kg:Water, h2kg:EthyleneGlycolDimethylEther, h2kg:EthyleneGlycolDiethylEther, h2kg:nButylAcetate, h2kg:Methanol, h2kg:CatalystInk, h2kg:PolyethyleneGlycol ;
  h2kg:hasOutputData h2kg:SolventPhysicalPropertyDataset ;
  h2kg:hasParameter h2kg:OperatingTemperature, h2kg:EthanolVolumeFractionInSolventMixture, h2kg:DropletVolume, h2kg:NeedleDiameter .


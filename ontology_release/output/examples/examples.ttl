  rdfs:label "Ink Formulation Specification"@en ;
  skos:altLabel "ink formulation"@en ;
  dcterms:description "Specification of DIW ink formulations: volume fractions of SMP-10, ZrB2, and SiC fiber; plus average chopped fiber length."@en ;

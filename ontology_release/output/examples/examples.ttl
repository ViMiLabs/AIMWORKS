  rdfs:label "Mesoporous Carbon Support"@en ;
  skos:altLabel "mesoporous carbon"@en, "MgO-templated mesoporous carbon"@en, "porous carbon"@en ;
  dcterms:description "Carbon support with mesoporous/nanoporous structure used for Pt/MPC catalysts; large (~1 µm) primary particles."@en .

h2kg:KetjenBlackEC300JCarbonSupport
  a h2kg:Matter ;
  skos:prefLabel "Ketjen Black EC 300 J Carbon Support"@en ;
  rdfs:label "Ketjen Black EC 300 J Carbon Support"@en ;
  skos:altLabel "Ketjen Black EC300J"@en, "EC300J"@en, "carbon black support"@en ;
  dcterms:description "Conventional porous carbon support (Ketjen Black EC300J) used for Pt/K reference catalysts."@en .

h2kg:PtMesoporousCarbonCatalyst
  a h2kg:Matter ;
  skos:prefLabel "Pt Mesoporous Carbon Catalyst"@en ;
  rdfs:label "Pt Mesoporous Carbon Catalyst"@en ;
  dcterms:description "Pt on mesoporous carbon (CNovel) catalyst powder / cathode catalyst layer."@en .

h2kg:PtKetjenBlackCatalyst
  a h2kg:Matter ;
  skos:prefLabel "Pt Ketjen Black Catalyst"@en ;
  rdfs:label "Pt Ketjen Black Catalyst"@en ;
  skos:altLabel "Pt/K"@en, "Pt/Ketjen catalyst"@en, "graphitized Ketjen black supported Pt catalyst"@en ;
  dcterms:description "Pt on Ketjen Black EC300J catalyst powder / cathode catalyst layer."@en .

h2kg:XRayDiffractionMeasurement
  a h2kg:Measurement ;
  skos:prefLabel "X Ray Diffraction Measurement"@en ;
  rdfs:label "X Ray Diffraction Measurement"@en ;
  skos:altLabel "XRD"@en, "X-ray diffraction"@en, "XRD measurement"@en ;
  dcterms:description "XRD used to estimate Pt crystallite size (Scherrer) and theoretical surface area."@en ;
  h2kg:measures h2kg:PtCrystalliteSize, h2kg:LatticeParameter, h2kg:TheoreticalMetalSurfaceArea, h2kg:CatalystPlatinumMassFraction, h2kg:CatalystRutheniumMassFraction, h2kg:DiffractionPeakPosition2Theta, h2kg:GrainSize, h2kg:MaximumReductionConversionRate, h2kg:ReductionOnsetTemperature, h2kg:ReductionCompletionTemperature, h2kg:DiffractionPeakPosition2Theta, h2kg:InterlayerSpacing, h2kg:GraphiticCrystalliteStackingSizeLc, h2kg:GraphiticPlanesPerCrystallite, h2kg:GraphiticPlaneOrientationOrderParameter, h2kg:PtAtomicPercent, h2kg:PtParticleSize, h2kg:XRDPeakPosition2Theta, h2kg:XRDPeakFWHM ;
  h2kg:usesInstrument h2kg:XRayDiffractometer, h2kg:MythenIIArrayDetector, h2kg:HotBlower ;
  h2kg:hasInputMaterial h2kg:FeNCCatalyst, h2kg:PorousAluminaCeramicCarrier, h2kg:PtOnCarbonCatalyst, h2kg:Carbonized3DPrintedCarbonMaterial, h2kg:TitaniumSubstrate, holy:CatalystLayer ;
  h2kg:hasParameter h2kg:XRayWavelength, h2kg:HeatingRate, h2kg:GasComposition, h2kg:XRayBeamEnergy, h2kg:ExposureTime, h2kg:XRDStepSize, h2kg:XRDTwoThetaStart, h2kg:XRDTwoThetaEnd ;
  h2kg:hasOutputData h2kg:XRDPatternDataset .

h2kg:NitrogenPhysisorptionMeasurement
  a h2kg:Measurement ;
  skos:prefLabel "Nitrogen Physisorption Measurement"@en ;
  rdfs:label "Nitrogen Physisorption Measurement"@en ;
  skos:altLabel "BET measurement"@en, "BET surface area measurement"@en, "nitrogen physisorption"@en ;
  dcterms:description "Nitrogen adsorption at 77 K to determine BET surface area and pore volume distribution (QSDFT)."@en ;
  h2kg:measures h2kg:BETSurfaceAreaNitrogen, h2kg:TotalPoreVolume, h2kg:QSDFTSurfaceAreaNitrogen, h2kg:PrimaryAgglomeratePoreSize, h2kg:AveragePoreDiameter, h2kg:TotalPoreVolume, h2kg:PoreSizeDistributionPeakDiameter, h2kg:AveragePoreSize, h2kg:PoreSizeDistribution, h2kg:PoreSurfaceAreaFractionBelow20nm, h2kg:MicroporeVolume ;
  h2kg:hasInputMaterial h2kg:CathodeCatalystLayer, h2kg:PtOnCarbonCatalyst, h2kg:Nitrogen, h2kg:Carbonized3DPrintedCarbonMaterial, h2kg:CarbonDioxide, h2kg:PtKetjenBlackCatalyst, h2kg:FeNCCatalyst ;
  h2kg:usesInstrument h2kg:GasAdsorptionAnalyzer, h2kg:BETAnalyzer, h2kg:BETSurfaceAnalyzer, h2kg:NitrogenAdsorptionAnalyzer, h2kg:GasAdsorptionAnalyzer, h2kg:GasSorptionAnalyzer ;
  h2kg:hasOutputData h2kg:PoreSizeDistributionDataset ;
  h2kg:hasParameter h2kg:SampleMass, h2kg:VacuumPressure .

h2kg:WaterVaporAdsorptionMeasurement
  a h2kg:Measurement ;
  skos:prefLabel "Water Vapor Adsorption Measurement"@en ;
  rdfs:label "Water Vapor Adsorption Measurement"@en ;
  skos:altLabel "water vapor adsorption"@en ;
  dcterms:description "Water vapor adsorption to estimate hydrophilicity and water uptake."@en ;
  h2kg:usesInstrument h2kg:GasSorptionAnalyzer ;
  h2kg:measures h2kg:WaterUptakeIndicator .

h2kg:MercuryIntrusionPorosimetryMeasurement
  a h2kg:Measurement ;
  skos:prefLabel "Mercury Intrusion Porosimetry Measurement"@en ;
  rdfs:label "Mercury Intrusion Porosimetry Measurement"@en ;
  skos:altLabel "mercury intrusion"@en, "mercury intrusion porosimetry"@en, "mercury porosimetry"@en ;
  dcterms:description "Mercury intrusion to quantify larger pore volume (>50 nm) in catalyst layers."@en ;
  h2kg:hasInputMaterial h2kg:CathodeCatalystLayer, pemfc:EMMO_143d21b5_d044_4af3_a9f9_22928f2516c1, h2kg:CarbonSupport, h2kg:PorousAluminaCeramicCarrier, h2kg:AnodeCatalystLayer, h2kg:VulcanXC72RCarbonBlack, holy:CatalystLayer ;
  h2kg:measures h2kg:TotalPoreVolume, h2kg:InterAgglomeratePoreSize, h2kg:ParticleDensity, h2kg:MeanFlowPoreDiameter, h2kg:AveragePoreSize, h2kg:AveragePoreDiameter, h2kg:PoreSizeDistribution, h2kg:OpenPorosity, h2kg:TotalPorosity, h2kg:CatalystLayerPorosity, h2kg:TrueDensity, h2kg:MesoporeDiameter, h2kg:MacroporeDiameter, h2kg:NanoscalePoreSizeMax, h2kg:PoreSizeDistributionPeakDiameter, h2kg:CrackVolumeAccessibilityAt20um, h2kg:CrackWidthD50_MIP ;
  h2kg:usesInstrument h2kg:MercuryPorosimeter, h2kg:MercuryIntrusionPorosimetryMeasurement3 ;
  h2kg:hasOutputData h2kg:PoreSizeDistributionDataset .

h2kg:LaserDiffractionScatteringParticleSizeMeasurement
  a h2kg:Measurement ;
  skos:prefLabel "Laser Diffraction Scattering Particle Size Measurement"@en ;
  rdfs:label "Laser Diffraction Scattering Particle Size Measurement"@en ;
  skos:altLabel "laser diffraction/scattering particle size analysis"@en, "laser diffraction"@en, "particle size distribution"@en ;
  dcterms:description "Particle size distribution analyzer (Horiba LA-960V2) for carbon support particle size distribution."@en ;
  h2kg:hasInputMaterial h2kg:CatalystInk, h2kg:GraphiteInkSuspension ;
  h2kg:measures h2kg:MeanParticleSize, h2kg:AgglomerateDiameter, h2kg:HydrodynamicDiameter, h2kg:ParticleSizeD50, h2kg:ParticleSizeD90 ;
  h2kg:usesInstrument h2kg:LaserDiffractionParticleSizeAnalyzer, h2kg:LaserParticleSizer ;
  h2kg:hasOutputData h2kg:AgglomerateSizeDistributionDataset .

h2kg:TransmissionLineModelAnalysis
  a h2kg:Measurement ;
  skos:prefLabel "Transmission Line Model Analysis"@en ;
  rdfs:label "Transmission Line Model Analysis"@en ;
  skos:altLabel "transmission line model"@en ;
  dcterms:description "Analysis method to extract proton resistance and Cdl from impedance spectra."@en ;

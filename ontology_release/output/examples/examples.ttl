<_HydrolysisRateSlowdownFactor_QV>
  a qudt:QuantityValue ;
  qudt:quantityKind quantitykind:Dimensionless .

<_OhmicResistanceReductionPercent_QV>
  a qudt:QuantityValue ;
  qudt:unit unit:PERCENT ;
  qudt:quantityKind quantitykind:Dimensionless .

<_PtParticleDiameterIncreasePercent_QV>
  a qudt:QuantityValue ;
  qudt:unit unit:PERCENT ;
  qudt:quantityKind quantitykind:Dimensionless .

<_ECSALossPercent_QV>
  a qudt:QuantityValue ;
  qudt:unit unit:PERCENT ;
  qudt:quantityKind quantitykind:Dimensionless, quantitykind:DimensionlessPercent, quantitykind:Percent .

<_PerformanceBenefitPercent_QV>
  a qudt:QuantityValue ;
  qudt:unit unit:PERCENT ;
  qudt:quantityKind quantitykind:Dimensionless, quantitykind:Percent .


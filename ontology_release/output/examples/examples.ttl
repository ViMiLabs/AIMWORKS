h2kg:StrainGaugeSensingMeasurement
  a h2kg:Measurement ;
  skos:prefLabel "Strain Gauge Sensing Measurement"@en ;
  rdfs:label "Strain Gauge Sensing Measurement"@en ;
  skos:altLabel "strain sensing"@en, "impedance-based strain measurement"@en, "strain sensor test"@en ;

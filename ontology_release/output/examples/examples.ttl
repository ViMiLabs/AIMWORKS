  a h2kg:Measurement ;
  skos:prefLabel "Transesterification Performance Measurement"@en ;
  rdfs:label "Transesterification Performance Measurement"@en ;
  dcterms:description "Assessment of catalytic performance for biodiesel production via soybean oil transesterification; quantified by GC-FID (EN14103)."@en ;
  h2kg:measures h2kg:FAMEContent ;
  h2kg:usesInstrument h2kg:GasChromatographFID ;
  h2kg:hasInputMaterial h2kg:SoybeanOil, h2kg:Methanol, h2kg:GeopolymerLatticeCatalyst ;
  h2kg:hasOutputMaterial h2kg:Biodiesel ;
  h2kg:hasParameter h2kg:ReactionTemperature, h2kg:ReactionTime, h2kg:MethanolExcessPercent, h2kg:CatalystWeightPercentInOil, h2kg:MethanolVolumePerOilVolume .


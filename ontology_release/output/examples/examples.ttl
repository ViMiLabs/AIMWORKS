  h2kg:measures h2kg:StrainGaugeFactor, h2kg:ShearStress, h2kg:LimitOfLinearityStrain ;
  h2kg:hasParameter h2kg:ShearStrain, h2kg:Frequency, h2kg:Temperature, h2kg:ACInputAmplitude, h2kg:TestDuration, h2kg:NumberOfCycles ;
  h2kg:usesInstrument h2kg:MechanicalActuationBioreactor, h2kg:ElectrochemicalWorkstation, h2kg:UniversalTestingMachine, h2kg:DigitalMultimeter ;
  h2kg:hasInputMaterial h2kg:StrainGaugeSensor, h2kg:PhosphateBufferedSaline .


  h2kg:hasParameter h2kg:ScanRate, h2kg:CellActiveArea, h2kg:ExternalResistance ;
  h2kg:hasInputMaterial h2kg:AirBreathingCathode, h2kg:ActivatedSludge, h2kg:SodiumAcetate, h2kg:PotassiumPhosphateBuffer, h2kg:PotassiumChlorideElectrolyte ;

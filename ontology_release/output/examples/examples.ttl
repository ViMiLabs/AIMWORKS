  h2kg:hasParameter h2kg:SinteringTemperature, h2kg:DwellTime, h2kg:HeatingRate, h2kg:XRayBeamEnergy, h2kg:VoxelSize, h2kg:ExposureTime, h2kg:AcceleratingVoltage, h2kg:XTMScanTime ;
  h2kg:hasInputMaterial h2kg:SmartElastomericCellularFoam, pemfc:EMMO_099d5163_117a_4176_ba48_af54a61c4c8d ;
  h2kg:hasOutputData h2kg:ExperimentDataset .


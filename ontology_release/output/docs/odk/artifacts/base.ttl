<http://purl.obolibrary.org/obo/h2kg/h2kg-base.ttl> rdf:type owl:Ontology ;
                                                     owl:versionIRI <http://purl.obolibrary.org/obo/h2kg/releases/2026-04-12/h2kg-base.ttl> ;
                                                     dc:type <http://purl.obolibrary.org/obo/IAO_8000001> ;
                                                     dcterms:abstract """Application ontology for representing low-Pt PEMFC cathode catalyst layer experiments, materials, manufacturing conditions, measurements, quantities, and release metadata with conservative alignment to EMMO, ECHO, QUDT, ChEBI, PROV-O, and Dublin Core Terms.
"""@en ;
                                                     dcterms:contributor "Institute of Energy Technologies (IET), Theory and Computation of Energy Materials (IET-3), Forschungszentrum Juelich GmbH, 52428 Juelich, Germany" ;
                                                     dcterms:created "2026-03-19" ;
                                                     dcterms:creator "Electrochemistry Research Group" ;
                                                     dcterms:description "Canonical schema module for the H2KG PEMFC catalyst-layer application ontology."@en ,
                                                                         "Ontology for representing proton exchange membrane fuel cell materials, components, devices, processes, measurements, and experiments." ;
                                                     dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
                                                     dcterms:modified "2026-03-19" ;
                                                     dcterms:publisher "Forschungszentrum Juelich GmbH" ;
                                                     dcterms:references <http://purl.org/holy/ns#> ,
                                                                        <https://w3id.org/emmo> ,
                                                                        <https://w3id.org/emmo/domain/electrochemistry> ,
                                                                        <https://w3id.org/emmo/domain/pemfc> ,
                                                                        <https://w3id.org/emmo/domain/characterisation-methodology/chameo#> ,
                                                                        <https://w3id.org/emmo/domain/coating#> ,
                                                                        <https://w3id.org/emmo/domain/equivalent-circuit-model#> ,
                                                                        <https://w3id.org/emmo/domain/manufacturing#> ,
                                                                        <https://w3id.org/emmo/domain/microscopy#> ;
                                                     dcterms:title "H2KG PEMFC Catalyst Layer Application Ontology"@en ,
                                                                   "H2KG: Ontology for Proton Exchange Membrane Fuel Cell Materials, Components, and Experiments" ;
                                                     vann:preferredNamespacePrefix "h2kg" ;
                                                     vann:preferredNamespaceUri h2kg: ;
                                                     rdfs:comment """The ontology captures PEMFC catalyst-layer experimental concepts, parameters, properties, measurements, instruments, materials, and related FAIR provenance. It preserves the historic h2kg namespace while improving metadata quality, release readiness, and public documentation.
"""@en ;
                                                     rdfs:seeAlso <http://purl.org/holy/ns#BipolarPlate> ,
                                                                  <http://purl.org/holy/ns#CatalystLayer> ,
                                                                  <http://purl.org/holy/ns#FuelCellStack> ,

                                                     dcterms:creator "Electrochemistry Research Group" ;
                                                     dcterms:description "Canonical schema module for the H2KG PEMFC catalyst-layer application ontology."@en ,
                                                                         "Ontology for representing proton exchange membrane fuel cell materials, components, devices, processes, measurements, and experiments." ;

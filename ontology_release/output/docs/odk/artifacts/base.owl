    <!-- https://w3id.org/h2kg/hydrogen-ontology#CatalystLayerMicrostructureSimulation -->

    <owl:NamedIndividual rdf:about="https://w3id.org/h2kg/hydrogen-ontology#CatalystLayerMicrostructureSimulation">
        <rdf:type rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Measurement"/>
        <h2kg:hasInputMaterial rdf:resource="http://purl.org/holy/ns#CatalystLayer"/>
        <h2kg:hasOutputData rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#ConductivityDataset"/>
        <h2kg:hasParameter rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#CarbonBlackVolumeFraction"/>
        <h2kg:hasParameter rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#IonomerToCarbonRatio"/>
        <h2kg:measures rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#RelativeProtonConductivity"/>
        <h2kg:measures rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#RelativeProtonConductivityCoefficientLowRIC"/>
        <h2kg:measures rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#RelativeProtonConductivityExponentRICHigh"/>
        <h2kg:measures rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#RelativeProtonConductivityExponentRICLow"/>
        <h2kg:measures rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#RelativeProtonConductivityExponentVCB"/>
        <h2kg:measures rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#RelativeProtonConductivityThresholdRIC"/>
        <dcterms:description xml:lang="en">Simulation that packs reconstructed CB aggregates into a 3D catalyst layer, applies ionomer coating model, and computes ionomer connectivity/tortuosity and relative proton conductivity.</dcterms:description>
        <rdfs:label xml:lang="en">Catalyst Layer Microstructure Simulation</rdfs:label>
        <skos:altLabel xml:lang="en">catalyst layer simulation</skos:altLabel>
        <skos:prefLabel xml:lang="en">Catalyst Layer Microstructure Simulation</skos:prefLabel>

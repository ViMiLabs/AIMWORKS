    <!-- https://w3id.org/h2kg/hydrogen-ontology#Agent -->

    <owl:Class rdf:about="https://w3id.org/h2kg/hydrogen-ontology#Agent">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <rdfs:comment xml:lang="en">Core H2KG class for responsible actors and provenance-bearing entities.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">Agent</rdfs:label>
        <skos:definition xml:lang="en">A person, organization, software system, or other actor that bears responsibility for an activity, resource, or assertion in H2KG.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#Data -->

    <owl:Class rdf:about="https://w3id.org/h2kg/hydrogen-ontology#Data">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">Core H2KG class for recorded informational outputs and data artefacts.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">Data</rdfs:label>
        <skos:definition xml:lang="en">A recorded informational entity that captures observations, derived results, metadata, or other digitally expressed content.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#DataPoint -->

    <owl:Class rdf:about="https://w3id.org/h2kg/hydrogen-ontology#DataPoint">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">Core H2KG class for individual recorded observations or values.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">Data Point</rdfs:label>
        <skos:definition xml:lang="en">An individual recorded value or observation within a dataset, measurement series, or derived data collection.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#Instrument -->

    <owl:Class rdf:about="https://w3id.org/h2kg/hydrogen-ontology#Instrument">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">Core H2KG class for experimental and processing apparatus.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">Instrument</rdfs:label>
        <skos:definition xml:lang="en">A device or apparatus used to perform, control, or monitor a measurement, manufacturing step, or experimental operation.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#Manufacturing -->

    <owl:Class rdf:about="https://w3id.org/h2kg/hydrogen-ontology#Manufacturing">
        <rdfs:subClassOf rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Process"/>
        <rdfs:comment xml:lang="en">Core H2KG class for fabrication, preparation, and assembly processes.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">Manufacturing</rdfs:label>
        <skos:definition xml:lang="en">A process that prepares, fabricates, modifies, or assembles a material, component, or device.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#Matter -->

    <owl:Class rdf:about="https://w3id.org/h2kg/hydrogen-ontology#Matter">
        <rdfs:comment xml:lang="en">Core H2KG class for material entities and physical artefacts.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">Matter</rdfs:label>
        <skos:definition xml:lang="en">A material entity, substance, mixture, component, or physical artefact used, produced, or studied in the domain.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#Measurement -->

    <owl:Class rdf:about="https://w3id.org/h2kg/hydrogen-ontology#Measurement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Process"/>
        <rdfs:comment xml:lang="en">Core H2KG class for value-determining experimental activities.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">Measurement</rdfs:label>
        <skos:definition xml:lang="en">A process that determines, estimates, or records the value of a property under specified conditions.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#Metadata -->

    <owl:Class rdf:about="https://w3id.org/h2kg/hydrogen-ontology#Metadata">
        <rdfs:comment xml:lang="en">Core H2KG class for descriptive information about resources and activities.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">Metadata</rdfs:label>
        <skos:definition xml:lang="en">Information that describes the provenance, identity, structure, context, or management of another resource.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#NormalizationBasis -->

    <owl:Class rdf:about="https://w3id.org/h2kg/hydrogen-ontology#NormalizationBasis"/>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#Parameter -->

    <owl:Class rdf:about="https://w3id.org/h2kg/hydrogen-ontology#Parameter">
        <rdfs:comment xml:lang="en">Core H2KG class for reusable condition and setting concepts.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">Parameter</rdfs:label>
        <skos:definition xml:lang="en">A condition, setting, or specified variable used to characterize how a process, measurement, or material state is defined.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#Process -->

    <owl:Class rdf:about="https://w3id.org/h2kg/hydrogen-ontology#Process">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment xml:lang="en">Core H2KG class for activities and operations in the experimental workflow.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">Process</rdfs:label>
        <skos:definition xml:lang="en">A temporally extended activity or operation that unfolds through one or more steps and may involve materials, instruments, parameters, and outputs.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#Property -->

    <owl:Class rdf:about="https://w3id.org/h2kg/hydrogen-ontology#Property">
        <rdfs:comment xml:lang="en">Core H2KG class for characteristics that can be observed, measured, or reported.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">Property</rdfs:label>
        <skos:definition xml:lang="en">A characteristic, attribute, or measurable feature of an entity, material, process, or system.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#Unit -->

    <owl:Class rdf:about="https://w3id.org/h2kg/hydrogen-ontology#Unit">
        <rdfs:comment xml:lang="en">Core H2KG class for measurement units used with quantity values.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">Unit</rdfs:label>
        <skos:definition xml:lang="en">A unit of measure used to express the magnitude of a quantity value in H2KG.</skos:definition>
    </owl:Class>
    



        <rdfs:seeAlso rdf:resource="https://www.fz-juelich.de/en/iet/iet-3/divisions-1/artificial-material-intelligence"/>
        <owl:priorVersion rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <owl:versionInfo xml:lang="en">1.0.0</owl:versionInfo>
        <owl:versionInfo>2026-04-12</owl:versionInfo>
        <foaf:homepage rdf:resource="https://www.fz-juelich.de/en/iet/iet-3/divisions-1/artificial-material-intelligence"/>
    </owl:Ontology>
    



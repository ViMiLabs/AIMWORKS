    <!-- http://www.w3.org/ns/prov#used -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#used"/>
    


    <!-- http://www.w3.org/ns/prov#wasGeneratedBy -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasGeneratedBy"/>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#atCurrentDensity -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#atCurrentDensity">
        <rdfs:domain rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#DataPoint"/>
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment xml:lang="en">Core H2KG relation for atcurrentdensity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">atCurrentDensity</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates an observation, result, or condition to the current-density setting at which it applies.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#fromMeasurement -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#fromMeasurement">
        <rdfs:domain rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#DataPoint"/>
        <rdfs:range rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Measurement"/>
        <rdfs:comment xml:lang="en">Core H2KG relation for frommeasurement.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">fromMeasurement</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates data, a result, or a derived statement to the measurement from which it originates.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#hasInputData -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#hasInputData">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#used"/>
        <rdfs:domain rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Process"/>
        <rdfs:range rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Data"/>
        <rdfs:comment xml:lang="en">Core H2KG relation for hasinputdata.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">hasInputData</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates a process, analysis, or transformation to data used as its input.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#hasInputMaterial -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#hasInputMaterial">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#used"/>
        <rdfs:domain rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Process"/>
        <rdfs:range rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Matter"/>
        <rdfs:comment xml:lang="en">Core H2KG relation for hasinputmaterial.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">hasInputMaterial</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates a process to a material that serves as an input to that process.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#hasOutputData -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#hasOutputData">
        <rdfs:domain rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Measurement"/>
        <rdfs:range rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Data"/>
        <rdfs:comment xml:lang="en">Core H2KG relation for hasoutputdata.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">hasOutputData</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates a process or measurement to data generated as its output.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#hasOutputMaterial -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#hasOutputMaterial">
        <rdfs:domain rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Process"/>
        <rdfs:range rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Matter"/>
        <rdfs:comment xml:lang="en">Core H2KG relation for hasoutputmaterial.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">hasOutputMaterial</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates a process to a material produced by that process.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#hasParameter -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#hasParameter">
        <rdfs:domain rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Process"/>
        <rdfs:range rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Parameter"/>
        <rdfs:comment xml:lang="en">Core H2KG relation for hasparameter.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">hasParameter</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates a process, measurement, or resource to a parameter used to characterize its conditions or settings.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#hasPart -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#hasPart">
        <owl:inverseOf rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#isPartOf"/>
        <rdfs:comment xml:lang="en">Core H2KG relation for haspart.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">hasPart</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates a composite entity to one of its constituent parts.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#hasProperty -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#hasProperty">
        <rdfs:domain rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Measurement"/>
        <rdfs:range rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Property"/>
        <rdfs:comment xml:lang="en">Core H2KG relation for hasproperty.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">hasProperty</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates a resource to a property that it bears, reports, or is described in terms of.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#hasQuantityValue -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#hasQuantityValue">
        <rdfs:comment xml:lang="en">Core H2KG relation for hasquantityvalue.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">hasQuantityValue</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates a parameter, property, or data point to a quantity-value node that carries its numeric value and unit.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#hasSubProcess -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#hasSubProcess">
        <owl:inverseOf rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#isSubProcessOf"/>
        <rdfs:comment xml:lang="en">Core H2KG relation for hassubprocess.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">hasSubProcess</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates a process to a subprocess that forms part of its execution.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#isPartOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#isPartOf">
        <rdfs:comment xml:lang="en">Core H2KG relation for ispartof.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">isPartOf</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates an entity to a larger entity of which it is a constituent part.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#isSubProcessOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#isSubProcessOf">
        <rdfs:comment xml:lang="en">Core H2KG relation for issubprocessof.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">isSubProcessOf</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates a subprocess to the larger process of which it forms a part.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#measures -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#measures">
        <rdfs:domain rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Measurement"/>
        <rdfs:range rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Property"/>
        <rdfs:comment xml:lang="en">Core H2KG relation for measures.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">measures</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates a measurement to the property it determines or quantifies.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#normalizedTo -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#normalizedTo">
        <rdfs:range rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#NormalizationBasis"/>
        <rdfs:comment xml:lang="en">Core H2KG relation for normalizedto.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">normalizedTo</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates a quantitative result or property to the basis against which it is normalized.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#ofProperty -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#ofProperty">
        <rdfs:domain rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#DataPoint"/>
        <rdfs:range rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#Property"/>
        <rdfs:comment xml:lang="en">Core H2KG relation for ofproperty.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/h2kg/hydrogen-ontology"/>
        <rdfs:label xml:lang="en">ofProperty</rdfs:label>
        <skos:definition xml:lang="en">An object property that relates a result, value, or derived statement to the property that it is about.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/h2kg/hydrogen-ontology#referenceElectrode -->

    <owl:ObjectProperty rdf:about="https://w3id.org/h2kg/hydrogen-ontology#referenceElectrode">

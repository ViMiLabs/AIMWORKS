<?xml version="1.0"?>
<rdf:RDF xmlns="http://purl.obolibrary.org/obo/h2kg/h2kg-base.owl#"
     xml:base="http://purl.obolibrary.org/obo/h2kg/h2kg-base.owl"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:dcat="http://www.w3.org/ns/dcat#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:h2kg="https://w3id.org/h2kg/hydrogen-ontology#"
     xmlns:prov="http://www.w3.org/ns/prov#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://purl.obolibrary.org/obo/h2kg/h2kg-base.owl">
        <owl:versionIRI rdf:resource="http://purl.obolibrary.org/obo/h2kg/releases/2026-04-12/h2kg-base.owl"/>
        <dc:type rdf:resource="http://purl.obolibrary.org/obo/IAO_8000001"/>
        <dcterms:abstract xml:lang="en">Application ontology for representing low-Pt PEMFC cathode catalyst layer experiments, materials, manufacturing conditions, measurements, quantities, and release metadata with conservative alignment to EMMO, ECHO, QUDT, ChEBI, PROV-O, and Dublin Core Terms.
</dcterms:abstract>
        <dcterms:contributor>Institute of Energy Technologies (IET), Theory and Computation of Energy Materials (IET-3), Forschungszentrum Juelich GmbH, 52428 Juelich, Germany</dcterms:contributor>
        <dcterms:created>2026-03-19</dcterms:created>
        <dcterms:creator>Electrochemistry Research Group</dcterms:creator>
        <dcterms:description xml:lang="en">Canonical schema module for the H2KG PEMFC catalyst-layer application ontology.</dcterms:description>
        <dcterms:description>Ontology for representing proton exchange membrane fuel cell materials, components, devices, processes, measurements, and experiments.</dcterms:description>
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <dcterms:modified>2026-03-19</dcterms:modified>
        <dcterms:publisher>Forschungszentrum Juelich GmbH</dcterms:publisher>
        <dcterms:references rdf:resource="http://purl.org/holy/ns#"/>
        <dcterms:references rdf:resource="https://w3id.org/emmo"/>
        <dcterms:references rdf:resource="https://w3id.org/emmo/domain/electrochemistry"/>
        <dcterms:references rdf:resource="https://w3id.org/emmo/domain/pemfc"/>
        <dcterms:references rdf:resource="https://w3id.org/emmo/domain/characterisation-methodology/chameo#"/>
        <dcterms:references rdf:resource="https://w3id.org/emmo/domain/coating#"/>
        <dcterms:references rdf:resource="https://w3id.org/emmo/domain/equivalent-circuit-model#"/>
        <dcterms:references rdf:resource="https://w3id.org/emmo/domain/manufacturing#"/>
        <dcterms:references rdf:resource="https://w3id.org/emmo/domain/microscopy#"/>
        <dcterms:title xml:lang="en">H2KG PEMFC Catalyst Layer Application Ontology</dcterms:title>
        <dcterms:title>H2KG: Ontology for Proton Exchange Membrane Fuel Cell Materials, Components, and Experiments</dcterms:title>
        <vann:preferredNamespacePrefix>h2kg</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#"/>
        <rdfs:comment xml:lang="en">The ontology captures PEMFC catalyst-layer experimental concepts, parameters, properties, measurements, instruments, materials, and related FAIR provenance. It preserves the historic h2kg namespace while improving metadata quality, release readiness, and public documentation.
</rdfs:comment>
        <rdfs:seeAlso rdf:resource="http://purl.org/holy/ns#BipolarPlate"/>
        <rdfs:seeAlso rdf:resource="http://purl.org/holy/ns#CatalystLayer"/>
        <rdfs:seeAlso rdf:resource="http://purl.org/holy/ns#FuelCellStack"/>

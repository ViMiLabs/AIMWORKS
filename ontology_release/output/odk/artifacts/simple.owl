    <owl:Ontology rdf:about="http://purl.obolibrary.org/obo/h2kg/h2kg-simple.owl">
        <owl:versionIRI rdf:resource="http://purl.obolibrary.org/obo/h2kg/releases/2026-04-09/h2kg-simple.owl"/>
        <terms:abstract xml:lang="en">Application ontology for representing low-Pt PEMFC cathode catalyst layer experiments, materials, manufacturing conditions, measurements, quantities, and release metadata with conservative alignment to EMMO, ECHO, QUDT, ChEBI, PROV-O, and Dublin Core Terms.
</terms:abstract>
        <terms:contributor>Institute of Energy Technologies (IET), Theory and Computation of Energy Materials (IET-3), Forschungszentrum Juelich GmbH, 52428 Juelich, Germany</terms:contributor>
        <terms:created>2026-03-19</terms:created>
        <terms:creator>Electrochemistry Research Group</terms:creator>
        <terms:description xml:lang="en">Canonical schema module for the H2KG PEMFC catalyst-layer application ontology.</terms:description>
        <terms:description>Ontology for representing proton exchange membrane fuel cell materials, components, devices, processes, measurements, and experiments.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified>2026-03-19</terms:modified>
        <terms:publisher>Forschungszentrum Juelich GmbH</terms:publisher>
        <terms:references rdf:resource="http://purl.org/holy/ns#"/>
        <terms:references rdf:resource="https://w3id.org/emmo"/>
        <terms:references rdf:resource="https://w3id.org/emmo/domain/electrochemistry"/>
        <terms:references rdf:resource="https://w3id.org/emmo/domain/pemfc"/>
        <terms:references rdf:resource="https://w3id.org/emmo/domain/characterisation-methodology/chameo#"/>
        <terms:references rdf:resource="https://w3id.org/emmo/domain/coating#"/>
        <terms:references rdf:resource="https://w3id.org/emmo/domain/equivalent-circuit-model#"/>
        <terms:references rdf:resource="https://w3id.org/emmo/domain/manufacturing#"/>
        <terms:references rdf:resource="https://w3id.org/emmo/domain/microscopy#"/>
        <terms:title xml:lang="en">H2KG PEMFC Catalyst Layer Application Ontology</terms:title>
        <terms:title>H2KG: Ontology for Proton Exchange Membrane Fuel Cell Materials, Components, and Experiments</terms:title>
        <vann:preferredNamespacePrefix>h2kg</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri rdf:resource="https://w3id.org/h2kg/hydrogen-ontology#"/>
        <rdfs:comment xml:lang="en">The ontology captures PEMFC catalyst-layer experimental concepts, parameters, properties, measurements, instruments, materials, and related FAIR provenance. It preserves the historic h2kg namespace while improving metadata quality, release readiness, and public documentation.
</rdfs:comment>

    "http://purl.org/dc/terms/title": [
      {
        "@value": "Hydrogen Experiments Ontology – Low-Pt PEMFC Cathode Catalyst Layers"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "Ontology for representing low-Pt PEM fuel-cell cathode catalyst layer experiments, focusing on ionomer/solvent effects on ECSA, high-frequency resistance, and oxygen-transport metrics over realistic operating conditions."
      }

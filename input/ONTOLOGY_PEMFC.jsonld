    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "proposed_definition=Post-fabrication acid treatment / washing of the catalyst-coated membrane (CCM) to remove leached metal ions (e.g., Ni2+) and improve mass transport.; Mentioned as improving H2/air performance and low-RH performance (Fig. 4)."
      }
